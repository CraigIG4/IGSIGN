<section class="flex items-center justify-center">
  <div class="py-10 mx-auto max-w-7xl">
    <div class="max-w-xl mx-auto">
      <div class="text-center">
        <div class="relative flex flex-col items-center">
          <%= render 'shared/logo', width: '100', height: '100' %>
          <h1 class="text-6xl font-bold mt-4 mb-2" style="color:#162B3C">
            IGSIGN
          </h1>
          <p class="text-sm font-semibold uppercase tracking-widest mb-4" style="color:#45AC34">
            Ignition Group e-Signing Portal
          </p>
        </div>
        <h2 class="mt-2 mb-16 text-lg text-center text-gray-600">
          Ignition Group&#39;s internal document signing platform. ECT Act 25 of 2002 compliant,
          secure, and built for the approval workflows your business actually uses.
        </h2>
      </div>
    </div>
    <div class="grid grid-cols-1 gap-12 md:gap-10 md:grid-cols-2">
      <div class="card bg-base-200">
        <div class="card-body">
          <div class="text-center transition-all">
            <div class="inline-block p-4 mb-4 -mt-16 rounded-full" style="background-color:#162B3C">
              <%= svg_icon('shield_check', class: 'w-10 h-10 text-base-100') %>
            </div>
            <h3 class="mb-4 text-2xl font-semibold">ECT Act Compliant</h3>
            <p class="text-base text-gray-500">
              Simple Electronic Signatures (SES) under the Electronic Communications
              and Transactions Act 25 of 2002 — legally valid for the vast majority of
              Ignition Group commercial documents.
            </p>
          </div>
        </div>
      </div>
      <div class="card bg-base-200">
        <div class="card-body">
          <div class="text-center transition-all">
            <div class="inline-block p-4 mb-4 -mt-16 rounded-full" style="background-color:#162B3C">
              <%= svg_icon('checks', class: 'w-10 h-10 text-base-100') %>
            </div>
            <h3 class="mb-4 text-2xl font-semibold">Contract Approval Workflow</h3>
            <p class="text-base text-gray-500">
              Structured CAF approval routing: BU Head → Procurement → BU Finance →
              CLO → CFO → COO → CEO. Internal approvals stay internal; counterparties
              only see what they need to sign.
            </p>
          </div>
        </div>
      </div>
      <div class="card bg-base-200">
        <div class="card-body">
          <div class="text-center transition-all">
            <div class="inline-block p-4 mb-4 -mt-16 rounded-full" style="background-color:#162B3C">
              <%= svg_icon('devices', class: 'w-10 h-10 text-base-100') %>
            </div>
            <h3 class="mb-4 text-2xl font-semibold">Sign Anywhere</h3>
            <p class="text-base text-gray-500">
              Review and sign from any device. Document forms are optimised for desktop
              and mobile so approvals are never held up by location.
            </p>
          </div>
        </div>
      </div>
      <div class="card bg-base-200">
        <div class="card-body">
          <div class="text-center transition-all">
            <div class="inline-block p-4 mb-4 -mt-16 rounded-full" style="background-color:#162B3C">
              <%= svg_icon('lock', class: 'w-10 h-10 text-base-100') %>
            </div>
            <h3 class="mb-4 text-2xl font-semibold">Self-Hosted &amp; Private</h3>
            <p class="text-base text-gray-500">
              Hosted entirely within Ignition Group infrastructure. Sensitive commercial
              documents never leave your control — no third-party SaaS, no data residency
              concerns.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>