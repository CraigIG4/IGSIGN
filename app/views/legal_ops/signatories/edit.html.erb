<% content_for :title, "Edit #{@signatory.full_name}" %>

<div class="max-w-2xl mx-auto px-4 py-8">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-slate-900">Edit Signatory</h1>
    <p class="text-sm text-slate-500 mt-1">
      Email and name are read-only. Change role title or seniority below.
    </p>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
    <div class="mb-4 pb-4 border-b border-slate-100">
      <p class="text-xs text-slate-500 uppercase font-medium mb-1">Name</p>
      <p class="text-slate-900 font-medium"><%= @signatory.full_name %></p>
    </div>
    <div class="mb-6 pb-4 border-b border-slate-100">
      <p class="text-xs text-slate-500 uppercase font-medium mb-1">Email</p>
      <p class="text-slate-900"><%= @signatory.email %></p>
    </div>

    <%= form_with model: [:legal_ops, @signatory], local: true do |f| %>
      <div class="mb-4">
        <%= f.label :role_title, 'Role Title', class: 'block text-sm font-medium text-slate-700 mb-1' %>
        <%= f.text_field :role_title,
              class: 'w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-500' %>
      </div>

      <div class="mb-6">
        <%= f.label :seniority, 'Seniority', class: 'block text-sm font-medium text-slate-700 mb-1' %>
        <%= f.select :seniority, IgSignatory::SENIORITY_LEVELS,
              { include_blank: '— select —' },
              class: 'w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-500' %>
      </div>

      <div class="flex gap-3">
        <%= f.submit 'Save Changes',
              class: 'px-4 py-2 rounded-lg font-medium text-sm text-white cursor-pointer focus:ring-2 focus:ring-green-500',
              style: 'background-color: #00C853;' %>
        <%= link_to 'Cancel', legal_ops_signatories_path,
              class: 'px-4 py-2 rounded-lg font-medium text-sm text-slate-600 bg-slate-100 hover:bg-slate-200' %>
      </div>
    <% end %>
  </div>
</div>
