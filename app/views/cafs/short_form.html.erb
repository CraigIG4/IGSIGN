<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Contract Approval Form &mdash; <%= @caf[:entity_name] %></title>
<style>
@import url('https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap');
*{margin:0;padding:0;box-sizing:border-box;}
html,body{background:white;}
body{font-family:'DM Sans',Arial,Helvetica,sans-serif;font-size:9pt;color:#1a1a1a;-webkit-print-color-adjust:exact;print-color-adjust:exact;}
.page{width:210mm;min-height:297mm;padding:22mm 22mm 18mm 22mm;}
.lh{width:100%;border-collapse:collapse;border-bottom:3pt solid #0B1722;margin-bottom:11pt;}
.lh td{padding-bottom:9pt;vertical-align:middle;}
.logo-badge{display:inline-block;background:#0B1722;color:white;font-size:13pt;font-weight:700;letter-spacing:2pt;padding:5pt 14pt 4pt;border-radius:3pt;}
.entity-name{font-size:10pt;font-weight:600;color:#0B1722;margin-top:5pt;line-height:1.3;}
.entity-meta{font-size:7.5pt;color:#6b7280;line-height:1.55;margin-top:2pt;white-space:pre-line;}
.lh-right{text-align:right;vertical-align:top;}
.form-title{font-size:13pt;font-weight:700;color:#0B1722;letter-spacing:0.5pt;}
.form-sub{font-size:9pt;color:#6b7280;margin-top:2pt;}
.type-badge{display:inline-block;background:#45AC34;color:white;font-size:7.5pt;font-weight:700;padding:2pt 11pt;border-radius:20pt;margin-top:5pt;letter-spacing:0.3pt;}
.wf-ref{font-size:7.5pt;color:#9ca3af;margin-top:5pt;}
.wf-date{font-size:8.5pt;color:#374151;font-weight:600;margin-top:1pt;}
.sh{border-left:3pt solid #00C853;background:#0B1722;color:white;font-size:7.5pt;font-weight:700;padding:5pt 9pt;margin-top:9pt;letter-spacing:0.8pt;text-transform:uppercase;}
.sh-green{border-left:3pt solid #00C853;background:#059669;color:white;font-size:7.5pt;font-weight:700;padding:5pt 9pt;margin-top:9pt;letter-spacing:0.8pt;text-transform:uppercase;}
.sh-amber{background:#d97706;color:white;font-size:7.5pt;font-weight:700;padding:5pt 9pt;margin-top:9pt;letter-spacing:0.6pt;text-transform:uppercase;}
.iv-na{font-size:8.5pt;padding:2pt 8pt 6pt;color:#9CA3AF;font-style:italic;}
.addendum-block{border:1pt solid #f59e0b;border-left:4pt solid #f59e0b;background:#fffbeb;padding:8pt 10pt;font-size:9pt;line-height:1.6;color:#92400e;margin-top:6pt;}
.prov-ai{display:inline-block;background:#dcfce7;color:#166534;font-size:6pt;font-weight:700;padding:1pt 5pt;border-radius:8pt;margin-left:4pt;}
.prov-manual{display:inline-block;background:#f3f4f6;color:#6b7280;font-size:6pt;font-weight:700;padding:1pt 5pt;border-radius:8pt;margin-left:4pt;}
.ig{width:100%;border-collapse:collapse;border:1pt solid #cbd5e1;}
.ig td{border-right:1pt solid #e2e8f0;border-bottom:1pt solid #e2e8f0;padding:0;vertical-align:top;}
.ig td.lc{border-right:none;}
.ig td.fw{border-right:none;}
.ig tr:last-child td{border-bottom:none;}
.il{font-size:7pt;font-weight:700;color:#0B1722;text-transform:uppercase;letter-spacing:0.5pt;padding:4pt 8pt 1pt;}
.iv{font-size:9pt;padding:2pt 8pt 6pt;color:#1a1a1a;line-height:1.4;}
.iv.pre{white-space:pre-line;}
.tb{border:1pt solid #cbd5e1;padding:7pt 9pt;min-height:36pt;font-size:9pt;line-height:1.6;white-space:pre-line;color:#1a1a1a;background:white;}
.tb-risk{border:1pt solid #fbbf24;background:#fffbeb;padding:7pt 9pt;min-height:28pt;font-size:9pt;line-height:1.6;white-space:pre-line;color:#92400e;}
.tb-na{border:1pt dashed #d1d5db;padding:7pt 9pt;font-size:8.5pt;color:#9ca3af;font-style:italic;}
.sg{width:100%;border-collapse:collapse;border:1pt solid #cbd5e1;}
.sg td{border-right:1pt solid #e2e8f0;border-bottom:1pt solid #e2e8f0;padding:0;vertical-align:top;}
.sg td.lc{border-right:none;}
.sg tr:last-child td{border-bottom:none;}
.doc-tbl{width:100%;border-collapse:collapse;border:1pt solid #cbd5e1;}
.doc-tbl th{background:#f8fafc;color:#0B1722;font-size:7.5pt;font-weight:700;padding:4pt 8pt;text-align:left;border-bottom:1pt solid #cbd5e1;border-right:1pt solid #e2e8f0;text-transform:uppercase;letter-spacing:0.3pt;}
.doc-tbl th:last-child{border-right:none;}
.doc-tbl td{padding:6pt 8pt;border-bottom:1pt solid #e2e8f0;border-right:1pt solid #e2e8f0;font-size:8.5pt;vertical-align:middle;}
.doc-tbl td:last-child{border-right:none;}
.doc-tbl tr:last-child td{border-bottom:none;}
.badge-int{display:inline-block;background:#fef3c7;color:#92400e;font-size:7pt;font-weight:600;padding:1pt 7pt;border-radius:10pt;}
.badge-ext{display:inline-block;background:#d1fae5;color:#065f46;font-size:7pt;font-weight:600;padding:1pt 7pt;border-radius:10pt;}
.dt{width:100%;border-collapse:collapse;font-size:8.5pt;}
.dt th{background:#f0f4f8;color:#0B1722;font-size:7.5pt;font-weight:700;padding:4pt 7pt;text-align:left;border:1pt solid #c8cbd4;text-transform:uppercase;letter-spacing:0.3pt;}
.dt td{padding:4pt 7pt;border:1pt solid #d4d7dd;vertical-align:top;}
.dt td.lc{font-weight:600;color:#0B1722;font-size:8pt;background:#f7f9fc;}
.an{font-size:7.5pt;color:#555;line-height:1.4;}
.sig-tbl{width:100%;border-collapse:collapse;font-size:8.5pt;}
.sig-tbl td{border:1pt solid #d4d7dd;padding:6pt 7pt;vertical-align:top;}
.sig-role{width:32%;background:#f7f9fc;}
.sig-area{width:43%;}
.sig-dt{width:25%;}
.sig-div{font-weight:700;font-size:8.5pt;color:#0B1722;}
.sig-org{font-size:7.5pt;color:#6b7280;margin-top:1pt;}
.sig-person{font-weight:600;font-size:8.5pt;margin-top:4pt;}
.sig-ptitle{font-size:7.5pt;color:#6b7280;margin-top:1pt;}
.sig-note{font-size:7pt;color:#6b7280;font-style:italic;line-height:1.4;margin-top:5pt;border-top:1pt solid #e5e7eb;padding-top:4pt;}
.sig-lbl{font-size:6.5pt;color:#9ca3af;text-transform:uppercase;letter-spacing:0.4pt;}
.sig-line{border-bottom:1pt solid #374151;height:32pt;margin:4pt 0 2pt;}
.sig-line-sm{border-bottom:1pt solid #374151;height:20pt;margin:4pt 0 2pt;}
.sig-tbl .hdr-row td{background:#0B1722;color:white;font-size:7.5pt;font-weight:700;text-transform:uppercase;letter-spacing:0.4pt;padding:4pt 7pt;}
.ecta{background:#eff6ff;border:1pt solid #bfdbfe;border-radius:3pt;padding:8pt 10pt;margin-top:10pt;font-size:7.5pt;color:#1e40af;line-height:1.55;}
.ftr{border-top:1pt solid #e2e8f0;margin-top:10pt;padding-top:5pt;font-size:7pt;color:#9ca3af;display:flex;justify-content:space-between;align-items:center;}
.conf{font-size:6.5pt;font-weight:700;color:#dc2626;text-transform:uppercase;letter-spacing:0.5pt;}
.sp-page{width:210mm;min-height:297mm;padding:22mm 22mm 18mm 22mm;page-break-before:always;}
.sp-hdr{border-bottom:3pt solid #0B1722;padding-bottom:6pt;margin-bottom:6pt;}
.sp-title{font-size:10pt;font-weight:800;color:#0B1722;text-transform:uppercase;letter-spacing:0.8pt;}
.sp-sub{font-size:7.5pt;color:#6b7280;margin-top:3pt;line-height:1.4;}
.sp-tbl{width:100%;border-collapse:collapse;font-size:8pt;table-layout:fixed;}
.sp-th{background:#0B1722;color:white;padding:4pt 7pt;font-size:7pt;font-weight:700;text-align:left;text-transform:uppercase;letter-spacing:0.3pt;border-right:1pt solid rgba(255,255,255,0.2);}
.sp-td-who{padding:5pt 7pt;vertical-align:top;border:1pt solid #d4d7dd;width:31%;height:32mm;}
.sp-td-sig{padding:5pt 7pt;vertical-align:top;border:1pt solid #d4d7dd;width:44%;}
.sp-td-dt{padding:5pt 7pt;vertical-align:top;border:1pt solid #d4d7dd;width:25%;}
.sp-name{font-size:8.5pt;font-weight:700;color:#0B1722;}
.sp-role{font-size:7pt;color:#6b7280;margin-top:2pt;}
.sp-line{border-bottom:1pt solid #374151;height:18mm;margin:4pt 0 2pt;}
.sp-lbl{font-size:6pt;color:#9ca3af;text-transform:uppercase;letter-spacing:0.3pt;margin-top:3pt;}
</style>
</head>
<body><div class="page">

<%# ── Letterhead ───────────────────────────────────────────────────────── %>
<table class="lh"><tr>
  <td>
    <div class="logo-badge">IGSIGN</div>
    <div class="entity-name"><%= @caf[:entity_name] %></div>
    <div class="entity-meta">Reg: <%= @caf[:entity_registration] %>
<%= @caf[:entity_address] %></div>
  </td>
  <td class="lh-right">
    <div class="form-title">CONTRACT APPROVAL FORM</div>
    <div class="form-sub">Internal Use Only &mdash; Confidential</div>
    <div class="type-badge">SHORT FORM CAF</div>
    <div class="wf-ref">Workflow #IGSIGN-<%= "%04d" % @caf[:agreement_id] %></div>
    <div class="wf-date"><%= @caf[:date_prepared] %></div>
  </td>
</tr></table>

<%# ── A. Party Details ─────────────────────────────────────────────────── %>
<div class="sh">A &mdash; Party Details</div>
<table class="ig">
  <tr>
    <td><div class="il">Agreement Type</div><div class="iv"><%= @caf[:agreement_type_label] %></div></td>
    <td class="lc"><div class="il">Date of Preparation</div><div class="iv"><%= @caf[:date_prepared] %></div></td>
  </tr>
  <tr>
    <td><div class="il">IG Contracting Entity</div><div class="iv"><%= @caf[:entity_name] %></div></td>
    <td class="lc"><div class="il">Registration Number</div><div class="iv"><%= @caf[:entity_registration] %></div></td>
  </tr>
  <tr>
    <td class="fw" colspan="2"><div class="il">Registered Address</div><div class="iv pre"><%= @caf[:entity_address] %></div></td>
  </tr>
  <tr>
    <td><div class="il">Counterparty / Contracting Party</div><div class="iv"><%= @caf[:counterparty_company].presence || '&mdash;' %></div></td>
    <td class="lc"><div class="il">Authorised Signatory</div><div class="iv"><%= @caf[:counterparty_contact_name].presence || '&mdash;' %></div></td>
  </tr>
  <tr>
    <td class="fw" colspan="2"><div class="il">Counterparty Signatory Email</div><div class="iv"><%= @caf[:counterparty_email].presence || '&mdash;' %></div></td>
  </tr>
  <tr>
    <td><div class="il">Requestor (sender)</div><div class="iv"><%= @caf[:requestor_name] %></div></td>
    <td class="lc"><div class="il">Requestor Email</div><div class="iv"><%= @caf[:requestor_email] %></div></td>
  </tr>
</table>

<%# ── B. Summary and Change ───────────────────────────────────────────── %>
<div class="sh">B &mdash; Agreement Summary</div>
<% summary = @caf[:high_level_summary].presence || @caf[:agreement_purpose].presence || @caf[:mandate_description].presence %>
<div style="border:1pt solid #cbd5e1;padding:9pt 10pt;font-size:9pt;line-height:1.65;color:#1a1a1a;background:#fafafa;<%= @caf[:parsed_data_provenance].to_h['high_level_summary'] == 'ai' ? 'font-style:italic;' : '' %>">
  <% if summary.present? %><%= summary %><% else %><span style="color:#9ca3af;font-style:italic;">Summary not yet available.</span><% end %>
</div>
<% if @caf[:change_in_addendum].present? %>
<div class="addendum-block">
  <div style="font-size:7pt;font-weight:700;text-transform:uppercase;letter-spacing:0.5pt;margin-bottom:4pt;">&#9650; Change from Parent Agreement</div>
  <%= @caf[:change_in_addendum] %>
</div>
<% end %>
<table class="sg" style="margin-top:6pt;">
  <tr>
    <td><div class="il">Contract Value</div><div class="<%= @caf[:agreement_value].present? ? 'iv' : 'iv-na' %>"><%= @caf[:agreement_value].presence || 'Not stated' %></div></td>
    <td><div class="il">Effective Date</div><div class="<%= @caf[:effective_date].present? ? 'iv' : 'iv-na' %>"><%= @caf[:effective_date].presence || 'Not stated' %></div></td>
    <td class="lc"><div class="il">Expiry Date</div><div class="<%= @caf[:expiry_date].present? ? 'iv' : 'iv-na' %>"><%= @caf[:expiry_date].presence || 'Not stated' %></div></td>
  </tr>
  <tr>
    <td><div class="il">Period</div><div class="<%= @caf[:period].present? ? 'iv' : 'iv-na' %>"><%= @caf[:period].presence || 'Not stated' %></div></td>
    <td><div class="il">Auto-Renewal</div><div class="iv"><%= @caf[:auto_renewal].nil? ? '<span class="iv-na">Not stated</span>' : (@caf[:auto_renewal] ? '<span style="color:#d97706;font-weight:600;">Yes &#9888;</span>' : 'No') %></div></td>
    <td class="lc"><div class="il">Payment Terms</div><div class="iv"><%= @caf[:payment_terms_days].present? ? "#{@caf[:payment_terms_days]} days" : (@caf[:payment_terms].presence || '&mdash;') %></div></td>
  </tr>
</table>
<% if @caf[:key_risks].present? %>
  <div class="sh-amber">&#9888; Material Risks</div>
  <div class="tb-risk"><%= @caf[:key_risks] %></div>
<% end %>

<%# ── C. Signing Package ───────────────────────────────────────────────── %>
<div class="sh">C &mdash; Signing Package</div>
<table class="doc-tbl">
  <tr><th style="width:5%">#</th><th style="width:45%">Document</th><th style="width:22%">Audience</th><th>Notes</th></tr>
  <tr>
    <td style="text-align:center;font-weight:700;">1</td>
    <td><strong><%= @caf[:agreement_type_label] %> Approval Form</strong><br><span style="font-size:7.5pt;color:#6b7280;">Auto-generated from agreement details</span></td>
    <td><span class="badge-int">&#128274; Internal only</span></td>
    <td style="font-size:8pt;color:#6b7280;">Reviewed by IG signatories. Not sent to counterparty.</td>
  </tr>
  <% if @caf[:document_name].present? %>
  <tr>
    <td style="text-align:center;font-weight:700;">2</td>
    <td><strong><%= @caf[:document_name] %></strong><br><span style="font-size:7.5pt;color:#6b7280;">Uploaded agreement document</span></td>
    <td><span class="badge-ext">&#128275; Shared with counterparty</span></td>
    <td style="font-size:8pt;color:#6b7280;">Executed by all parties in Stage 2.</td>
  </tr>
  <% end %>
</table>

<%# ── D. Mandate Assessment ───────────────────────────────────────────── %>
<div class="sh">D &mdash; Mandate Assessment by Department</div>
<table class="dt">
  <tr><th style="width:20%">Department</th><th style="width:20%">Signatory</th><th style="width:36%">Approval Statement</th><th style="width:12%">Signature</th><th style="width:12%">Date</th></tr>
  <tr><td class="lc">Group Procurement</td><td>Ms Callie Baney</td><td class="an">I confirm the counterparty has satisfied Procurement onboarding requirements.</td><td><div style="height:24pt;border-bottom:1pt solid #555;"></div></td><td><div style="height:24pt;border-bottom:1pt solid #555;"></div></td></tr>
  <tr><td class="lc">Business Unit Finance</td><td><%= @caf[:bu_finance_name] %></td><td class="an">I confirm the commercials are in line with approved budget and financial forecasts.</td><td><div style="height:24pt;border-bottom:1pt solid #555;"></div></td><td><div style="height:24pt;border-bottom:1pt solid #555;"></div></td></tr>
  <tr><td class="lc">Group Legal</td><td>Craig G. Lawrence</td><td class="an">I confirm the contract has been reviewed and approved by the Legal Department.</td><td><div style="height:24pt;border-bottom:1pt solid #555;"></div></td><td><div style="height:24pt;border-bottom:1pt solid #555;"></div></td></tr>
</table>

<%# ── E. Internal Approval Chain ─────────────────────────────────────── %>
<div class="sh-green">E &mdash; Internal Approval Chain</div>
<table class="sig-tbl">
  <tr class="hdr-row">
    <td class="sig-role">Role &amp; Signatory</td>
    <td class="sig-area">Signature &amp; Full Name</td>
    <td class="sig-dt">Date &amp; Capacity</td>
  </tr>
  <%# Requestor %>
  <tr>
    <td class="sig-role">
      <div class="sig-div">Requestor</div>
      <div class="sig-org">Agreement Originator</div>
      <div class="sig-person"><%= @caf[:requestor_name] %></div>
      <div class="sig-ptitle"><%= @caf[:requestor_email] %></div>
      <div class="sig-note">I have read and understood all commercial terms. I approve that the IG entity should be bound by the terms of this agreement.</div>
    </td>
    <td class="sig-area">
      <div class="sig-lbl">Signature</div><div class="sig-line"></div>
      <div class="sig-lbl">Full Name (print)</div><div class="sig-line-sm"></div>
    </td>
    <td class="sig-dt">
      <div class="sig-lbl">Date</div><div class="sig-line-sm"></div>
      <div class="sig-lbl">Capacity</div><div class="sig-line-sm"></div>
    </td>
  </tr>
  <%# BU Heads %>
  <% @caf[:bu_heads].each do |person| %>
  <tr>
    <td class="sig-role">
      <div class="sig-div">Ignition Group</div>
      <div class="sig-org">Business Unit Head</div>
      <div class="sig-person"><%= person[:name] %></div>
      <div class="sig-ptitle"><%= person[:title] %></div>
      <div class="sig-note">I confirm this agreement is necessary for IG commercial purposes and I approve the business case.</div>
    </td>
    <td class="sig-area">
      <div class="sig-lbl">Signature</div><div class="sig-line"></div>
      <div class="sig-lbl">Full Name (print)</div><div class="sig-line-sm"></div>
    </td>
    <td class="sig-dt">
      <div class="sig-lbl">Date</div><div class="sig-line-sm"></div>
      <div class="sig-lbl">Capacity</div><div class="sig-line-sm"></div>
    </td>
  </tr>
  <% end %>
  <%# Group CLO %>
  <tr>
    <td class="sig-role">
      <div class="sig-div">Ignition Group</div>
      <div class="sig-org">Chief Legal Officer</div>
      <div class="sig-person">Craig G. Lawrence</div>
      <div class="sig-ptitle">Group CLO</div>
    </td>
    <td class="sig-area">
      <div class="sig-lbl">Signature</div><div class="sig-line"></div>
      <div class="sig-lbl">Full Name (print)</div><div class="sig-line-sm"></div>
    </td>
    <td class="sig-dt">
      <div class="sig-lbl">Date</div><div class="sig-line-sm"></div>
      <div class="sig-lbl">Capacity</div><div class="sig-line-sm"></div>
    </td>
  </tr>
  <%# CEO %>
  <tr>
    <td class="sig-role">
      <div class="sig-div">Ignition Group</div>
      <div class="sig-org">Chief Executive Officer</div>
      <div class="sig-person">Sean Bergsma</div>
      <div class="sig-ptitle">Group CEO</div>
      <div class="sig-note">Approval noted as per signature to the executed Agreement.</div>
    </td>
    <td class="sig-area">
      <div class="sig-lbl">Signature</div><div class="sig-line"></div>
      <div class="sig-lbl">Full Name (print)</div><div class="sig-line-sm"></div>
    </td>
    <td class="sig-dt">
      <div class="sig-lbl">Date</div><div class="sig-line-sm"></div>
      <div class="sig-lbl">Capacity</div><div class="sig-line-sm"></div>
    </td>
  </tr>
</table>

<%# ── F. ECTA Compliance Notice ──────────────────────────────────────── %>
<div class="ecta">
  <strong>Electronic Signatures &mdash; ECT Act Notice.</strong>
  This Contract Approval Form is executed as an electronic document pursuant to the
  <strong>Electronic Communications and Transactions Act 25 of 2002 (ECT Act)</strong>.
  All signatures appended hereto constitute valid, binding and enforceable electronic
  signatures (SES-grade) as defined in the ECT Act. Each signatory confirms they are
  duly authorised to bind the relevant Ignition Group entity to the terms of this
  agreement. Executed via IGSIGN &mdash; Ignition Group&rsquo;s internal electronic
  signing platform.
</div>

<%# ── Footer ─────────────────────────────────────────────────────────── %>
<div class="ftr">
  <div>
    <span class="conf">CONFIDENTIAL &mdash; INTERNAL USE ONLY</span><br>
    IGSIGN &mdash; Ignition Group &mdash; Not for external distribution
  </div>
  <div style="text-align:right;">
    Workflow #IGSIGN-<%= "%04d" % @caf[:agreement_id] %> &mdash; Generated <%= @caf[:date_prepared] %>
  </div>
</div>

</div>

<%# ── Electronic Signing Page (last page — DocuSeal places fields here) ── %>
<div class="sp-page">
  <div class="sp-hdr">
    <div class="sp-title">Electronic Signature Page &mdash; Internal Approvals</div>
    <div class="sp-sub">
      Workflow #IGSIGN-<%= "%04d" % @caf[:agreement_id] %> &mdash;
      Each signatory below confirms they have reviewed the Contract Approval Form and
      approves the transaction as set out therein. Valid electronic signatures under the ECT Act 25 of 2002.
    </div>
  </div>
  <table class="sp-tbl">
    <thead>
      <tr>
        <th class="sp-th" style="width:31%;">Signatory</th>
        <th class="sp-th" style="width:44%;">Signature</th>
        <th class="sp-th" style="width:25%;border-right:none;">Date</th>
      </tr>
    </thead>
    <tbody>
      <% (@caf[:signing_rows] || []).each do |row| %>
      <tr>
        <td class="sp-td-who">
          <div class="sp-name"><%= row[:name] %></div>
          <div class="sp-role"><%= row[:title] %></div>
        </td>
        <td class="sp-td-sig">
          <div class="sp-lbl">Electronic Signature</div>
          <div class="sp-line"></div>
        </td>
        <td class="sp-td-dt">
          <div class="sp-lbl">Date Signed</div>
          <div class="sp-line"></div>
        </td>
      </tr>
      <% end %>
    </tbody>
  </table>
  <div style="margin-top:10pt;padding:7pt 10pt;background:#f0fdf4;border:1pt solid #bbf7d0;border-radius:3pt;font-size:7pt;color:#15803d;line-height:1.5;">
    <strong>IGSIGN Electronic Execution:</strong>
    This signing page is completed digitally via IGSIGN. Each signatory receives a unique
    signing link by email. An audit trail is maintained for each signing event.
  </div>
</div>

