<div class="max-w-lg mx-auto px-2">
  <h1 class="text-4xl font-bold text-center mt-8">
    <%= t('change_your_password') %>
  </h1>
  <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: 'space-y-6' }) do |f| %>
    <div class="space-y-2">
      <%= render 'devise/shared/error_messages', resource: %>
      <%= f.hidden_field :reset_password_token %>
      <div class="form-control">
        <%= f.label :password, t('new_password'), class: 'label' %>
        <password-input class="block relative">
          <%= f.password_field :password, autofocus: true, autocomplete: 'new-password', class: 'base-input pr-10',
                               data: { target: 'password-input.passwordInput' } %>
          <button type="button" tabindex="-1"
                  class="absolute inset-y-0 right-0 flex items-center pr-3 text-gray-400 hover:text-gray-600"
                  data-target="password-input.togglePasswordVisibility">
            <span data-target="password-input.hiddenPasswordIcon">
              <%= svg_icon('eye', class: 'w-5 h-5') %>
            </span>
            <span data-target="password-input.visiblePasswordIcon" class="hidden">
              <%= svg_icon('eye_off', class: 'w-5 h-5') %>
            </span>
          </button>
        </password-input>
        <% if @minimum_password_length %>
          <label class="label">
            <span class="label-text">(<%= t('minimum_password_length_characters_minimum', minimum_password_length: @minimum_password_length) %>)</span>
          </label>
        <% end %>
      </div>
      <div class="form-control">
        <%= f.label :password_confirmation, t('confirm_new_password'), class: 'label' %>
        <password-input class="block relative">
          <%= f.password_field :password_confirmation, autocomplete: 'new-password', class: 'base-input pr-10',
                               data: { target: 'password-input.passwordInput' } %>
          <button type="button" tabindex="-1"
                  class="absolute inset-y-0 right-0 flex items-center pr-3 text-gray-400 hover:text-gray-600"
                  data-target="password-input.togglePasswordVisibility">
            <span data-target="password-input.hiddenPasswordIcon">
              <%= svg_icon('eye', class: 'w-5 h-5') %>
            </span>
            <span data-target="password-input.visiblePasswordIcon" class="hidden">
              <%= svg_icon('eye_off', class: 'w-5 h-5') %>
            </span>
          </button>
        </password-input>
      </div>
    </div>
    <div class="form-control">
      <%= f.button button_title(title: t('change_my_password'), disabled_with: t('changing_password')), class: 'base-button' %>
    </div>
  <% end %>
</div>
