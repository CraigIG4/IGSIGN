<%= render 'shared/navbar_warning' %>
<mobile-menu data-menu-id="igsign-mobile-nav">
<nav class="w-full mb-6 border-b ig-topnav" style="background-color:#162B3C; border-color:#0d1f2d; position:relative; z-index:50;">
  <div class="max-w-7xl mx-auto px-4 md:px-6 flex items-center justify-between" style="height:60px;">

    <%# Logo %>
    <a href="<%= root_path %>" style="text-decoration:none; display:flex; align-items:center; gap:10px; flex-shrink:0;">
      <%= render 'shared/logo', dark: true, height: '36' %>
    </a>

    <% if signed_in? %>
      <%# ── Primary nav — desktop ─────────────────────────────────────────────── %>
      <% current_path = request.path %>
      <% is_legal_ops = current_path.start_with?('/legal_ops') %>

      <div style="display:flex; align-items:center; gap:4px; flex:1; margin:0 24px;">

        <%# Agreements %>
        <% agreements_active = current_path.start_with?('/agreements') %>
        <a href="<%= agreements_path %>"
           style="display:inline-flex; align-items:center; padding:6px 12px 5px; font-size:14px; font-weight:500; text-decoration:none; transition:color 0.15s;
                  color: <%= agreements_active ? '#ffffff' : 'rgba(255,255,255,0.85)' %> !important;
                  border-bottom: 2px solid <%= agreements_active ? '#45AC34' : 'transparent' %>;"
           onmouseover="this.style.setProperty('color','#fff','important');"
           onmouseout="this.style.setProperty('color',this.dataset.active==='true'?'#fff':'rgba(255,255,255,0.85)','important');"
           data-active="<%= agreements_active %>">
          Agreements
        </a>

        <%# Counterparties %>
        <% cp_active = current_path.start_with?('/companies') %>
        <a href="<%= companies_path %>"
           style="display:inline-flex; align-items:center; padding:6px 12px 5px; font-size:14px; font-weight:500; text-decoration:none; transition:color 0.15s;
                  color: <%= cp_active ? '#ffffff' : 'rgba(255,255,255,0.85)' %> !important;
                  border-bottom: 2px solid <%= cp_active ? '#45AC34' : 'transparent' %>;"
           onmouseover="this.style.setProperty('color','#fff','important');"
           onmouseout="this.style.setProperty('color',this.dataset.active==='true'?'#fff':'rgba(255,255,255,0.85)','important');"
           data-active="<%= cp_active %>">
          Counterparties
        </a>

        <%# Legal Ops — admin only, with dropdown ─────────────────────────────── %>
        <% if current_user.role == User::ADMIN_ROLE %>
          <div class="dropdown dropdown-hover" style="z-index:200;">
            <label tabindex="0"
                   style="display:inline-flex; align-items:center; gap:4px; padding:6px 12px 5px; font-size:14px; font-weight:500; cursor:pointer; user-select:none;
                          color: <%= is_legal_ops ? '#ffffff' : 'rgba(255,255,255,0.85)' %> !important;
                          border-bottom: 2px solid <%= is_legal_ops ? '#45AC34' : 'transparent' %>;"
                   onmouseover="this.style.setProperty('color','#fff','important');"
                   onmouseout="this.style.setProperty('color','<%= is_legal_ops ? '#fff' : 'rgba(255,255,255,0.85)' %>','important');">
              Legal Ops
              <svg xmlns="http://www.w3.org/2000/svg" style="width:12px;height:12px;opacity:0.7;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="m6 9 6 6 6-6"/>
              </svg>
            </label>
            <ul tabindex="0"
                class="dropdown-content z-50 p-2 mt-0 shadow-xl menu bg-base-100 rounded-xl"
                style="min-width:210px; border:1px solid #e8ebed; top:100%; left:0;">
              <li>
                <%= link_to legal_ops_approval_matrices_path, class: 'flex items-center gap-2 text-sm font-medium' do %>
                  <%= svg_icon('table', class: 'w-4 h-4 flex-shrink-0 text-gray-400') %>
                  Approval Matrices
                <% end %>
              </li>
              <li>
                <%= link_to legal_ops_templates_path, class: 'flex items-center gap-2 text-sm font-medium' do %>
                  <%= svg_icon('document', class: 'w-4 h-4 flex-shrink-0 text-gray-400') %>
                  Templates
                <% end %>
              </li>
              <li>
                <%= link_to legal_ops_signatories_path, class: 'flex items-center gap-2 text-sm font-medium' do %>
                  <%= svg_icon('users', class: 'w-4 h-4 flex-shrink-0 text-gray-400') %>
                  Signatory Registry
                <% end %>
              </li>
              <li>
                <%= link_to legal_ops_workflows_path, class: 'flex items-center gap-2 text-sm font-medium' do %>
                  <%= svg_icon('collection', class: 'w-4 h-4 flex-shrink-0 text-gray-400') %>
                  Workflow Log
                <% end %>
              </li>
            </ul>
          </div>
        <% end %>

      </div>

      <%# ── Right section ──────────────────────────────────────────────────────── %>
      <div style="display:flex; align-items:center; gap:8px;">
        <%# + New Agreement %>
        <a href="<%= new_agreement_path %>"
           style="display:none; align-items:center; gap:6px; padding:6px 12px; border-radius:6px; font-size:12px; font-weight:600; color:#ffffff !important; border:1px solid rgba(255,255,255,0.25); text-decoration:none; transition:background 0.15s;"
           class="md:!flex"
           onmouseover="this.style.background='rgba(255,255,255,0.1)';"
           onmouseout="this.style.background='transparent';">
          <svg xmlns="http://www.w3.org/2000/svg" style="width:14px;height:14px;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/>
          </svg>
          New Agreement
        </a>

        <%# Settings %>
        <a href="<%= settings_profile_index_path %>"
           title="Settings"
           aria-label="Settings"
           id="account_settings_button"
           style="display:flex; align-items:center; gap:5px; padding:6px 10px; border-radius:6px; color:rgba(255,255,255,0.85) !important; text-decoration:none; transition:background 0.15s; font-size:14px; font-weight:500;"
           onmouseover="this.style.background='rgba(255,255,255,0.1)'; this.style.setProperty('color','#fff','important');"
           onmouseout="this.style.background='transparent'; this.style.setProperty('color','rgba(255,255,255,0.85)','important');">
          <svg xmlns="http://www.w3.org/2000/svg" style="width:17px;height:17px;flex-shrink:0;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
            <circle cx="12" cy="12" r="3"/>
            <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
          </svg>
          <span class="hidden md:inline">Settings</span>
        </a>

        <%# User avatar dropdown %>
        <div class="dropdown dropdown-end" style="z-index:100;">
          <label tabindex="0"
                 style="cursor:pointer; display:flex; align-items:center; justify-content:center; border-radius:50%; font-weight:700; font-size:13px; width:34px; height:34px; background-color:#45AC34; color:#162B3C; flex-shrink:0;">
            <%= current_user.initials %>
          </label>
          <ul tabindex="0"
              class="dropdown-content z-50 p-2 mt-2 shadow-xl menu bg-base-100 rounded-xl"
              style="min-width:190px; border:1px solid #e8ebed;">
            <li>
              <%= link_to settings_profile_index_path, class: 'flex items-center gap-2 text-sm' do %>
                <%= svg_icon('adjustments', class: 'w-4 h-4 flex-shrink-0') %><%= t('profile') %>
              <% end %>
            </li>
            <% if can?(:manage, EncryptedConfig) && !Docuseal.demo? %>
              <li>
                <%= link_to Docuseal.multitenant? ? console_redirect_index_path : Docuseal::CONSOLE_URL,
                    data: { prefetch: false }, class: 'flex items-center gap-2 text-sm' do %>
                  <%= svg_icon('terminal', class: 'w-4 h-4 flex-shrink-0') %><%= t('console') %>
                <% end %>
              </li>
            <% end %>
            <% if can?(:read, EncryptedConfig.new(key: EncryptedConfig::ESIGN_CERTS_KEY, account: current_account)) %>
              <li>
                <%= link_to settings_esign_path, class: 'flex items-center gap-2 text-sm' do %>
                  <%= svg_icon('zoom_check', class: 'w-4 h-4 flex-shrink-0') %><%= t('verify_pdf') %>
                <% end %>
              </li>
            <% end %>
            <% if (can?(:manage, EncryptedConfig) && current_user == true_user) || (current_user != true_user && current_account.testing?) %>
              <%= form_for '', url: testing_account_path, method: current_account.testing? ? :delete : :get, html: { class: 'w-full py-1' } do |f| %>
                <label class="flex items-center px-3 py-2 border-y border-base-300 text-sm gap-2" for="testing_toggle">
                  <submit-form data-on="change" class="flex">
                    <%= f.check_box :testing_toggle, class: 'toggle toggle-sm', checked: current_account.testing? %>
                  </submit-form>
                  <%= t('test_mode') %>
                </label>
              <% end %>
            <% end %>
            <li class="border-t border-base-300 mt-1 pt-1">
              <%= button_to destroy_user_session_path, method: :delete, data: { turbo: false },
                  class: 'flex items-center gap-2 text-sm w-full text-left' do %>
                <%= svg_icon('logout', class: 'w-4 h-4 flex-shrink-0') %><%= t('sign_out') %>
              <% end %>
            </li>
          </ul>
        </div>

        <%# Mobile hamburger %>
        <button class="md:hidden" data-action="toggle" aria-label="Open navigation" aria-expanded="false"
                style="color:#fff; background:none; border:none; padding:4px; cursor:pointer;">
          <svg style="width:20px;height:20px;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </button>
      </div>

    <% else %>
      <% if request.path != new_user_session_path && request.path != setup_index_path %>
        <%= link_to new_user_session_path({ lang: params[:lang] }.compact_blank),
            class: 'flex items-center gap-1.5 text-sm font-semibold',
            style: 'color:#ffffff; text-decoration:none;' do %>
          <%= svg_icon('login', class: 'w-5 h-5') %>
          <span><%= t('sign_in') %></span>
        <% end %>
      <% end %>
    <% end %>

  </div>

  <%# ── Mobile nav drawer ──────────────────────────────────────────────────────── %>
  <% if signed_in? %>
    <div id="igsign-mobile-nav"
         style="display:none; flex-direction:column; padding:8px 16px 12px; border-top:1px solid rgba(255,255,255,0.1); background-color:#162B3C;">
      <% current_path = request.path %>

      <%# Agreements %>
      <% mob_active = current_path.start_with?('/agreements') %>
      <a href="<%= agreements_path %>"
         style="display:block; padding:10px 12px; border-radius:6px; font-size:14px; font-weight:500; text-decoration:none; margin-bottom:2px;
                color: <%= mob_active ? '#ffffff' : 'rgba(255,255,255,0.85)' %> !important;
                border-left: 3px solid <%= mob_active ? '#45AC34' : 'transparent' %>;
                background: <%= mob_active ? 'rgba(255,255,255,0.08)' : 'transparent' %>;">
        Agreements
      </a>

      <%# Counterparties %>
      <% mob_cp = current_path.start_with?('/companies') %>
      <a href="<%= companies_path %>"
         style="display:block; padding:10px 12px; border-radius:6px; font-size:14px; font-weight:500; text-decoration:none; margin-bottom:2px;
                color: <%= mob_cp ? '#ffffff' : 'rgba(255,255,255,0.85)' %> !important;
                border-left: 3px solid <%= mob_cp ? '#45AC34' : 'transparent' %>;
                background: <%= mob_cp ? 'rgba(255,255,255,0.08)' : 'transparent' %>;">
        Counterparties
      </a>

      <%# Legal Ops (admin only) — section header + sub-links indented %>
      <% if current_user.role == User::ADMIN_ROLE %>
        <% mob_lo = current_path.start_with?('/legal_ops') %>
        <div style="padding:10px 12px 4px; font-size:11px; font-weight:700; color:rgba(255,255,255,0.4); letter-spacing:3px; text-transform:uppercase; margin-top:6px;">
          Legal Ops
        </div>
        <% [
          ['Approval Matrices', legal_ops_approval_matrices_path],
          ['Templates',         legal_ops_templates_path],
          ['Signatory Registry',legal_ops_signatories_path],
          ['Workflow Log',      legal_ops_workflows_path]
        ].each do |label, path| %>
          <% sub_active = current_path.start_with?(path) %>
          <a href="<%= path %>"
             style="display:block; padding:8px 12px 8px 24px; border-radius:6px; font-size:13px; font-weight:500; text-decoration:none; margin-bottom:2px;
                    color: <%= sub_active ? '#ffffff' : 'rgba(255,255,255,0.75)' %> !important;
                    border-left: 3px solid <%= sub_active ? '#45AC34' : 'transparent' %>;
                    background: <%= sub_active ? 'rgba(255,255,255,0.08)' : 'transparent' %>;">
            <%= label %>
          </a>
        <% end %>
      <% end %>

      <div style="border-top:1px solid rgba(255,255,255,0.1); margin-top:6px; padding-top:8px; display:flex; gap:10px; align-items:center;">
        <%= link_to '+ New Agreement', new_agreement_path,
            style: 'font-size:13px; font-weight:600; color:#45AC34; text-decoration:none;' %>
        <%= link_to 'Settings', settings_profile_index_path,
            style: 'font-size:13px; color:rgba(255,255,255,0.85) !important; text-decoration:none;' %>
      </div>
    </div>
  <% end %>

</nav>
</mobile-menu>
