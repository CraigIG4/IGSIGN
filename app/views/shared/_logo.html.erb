<%
  dark    = local_assigns.fetch(:dark, false)
  tagline = local_assigns.fetch(:tagline, false)
  h       = local_assigns.fetch(:height, '44').to_s.gsub(/[^0-9]/, '').presence || '44'

  if tagline && dark
    src = '/brand/igsign-primary-dark.svg'
  elsif tagline
    src = '/brand/igsign-primary-light.svg'
  elsif dark
    src = '/brand/igsign-nav-dark.svg'
  else
    src = '/brand/igsign-wordmark.svg'
  end
%>
<img src="<%= src %>" alt="IGSIGN" style="height:<%= h %>px; width:auto; display:block; flex-shrink:0;">
