<% content_for :title, "#{@agreement.agreement_type_label} — #{@agreement.contracting_party}" %>

<div class="max-w-3xl mx-auto px-4 py-8">

  <%# ── Header ──────────────────────────────────────────────────────────────── %>
  <div class="flex items-start justify-between mb-6">
    <div>
      <%= link_to agreements_path, class: 'text-xs text-gray-400 hover:text-gray-600 flex items-center gap-1 mb-2' do %>
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 12H5m7-7-7 7 7 7"/></svg>
        All Agreements
      <% end %>
      <h1 class="text-2xl font-bold text-gray-900">
        <%= @agreement.contracting_party.presence || 'Counterparty TBC' %>
      </h1>
      <div class="flex items-center gap-2 mt-1">
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold text-white"
              style="background-color:#1a2332;">
          <%= @agreement.agreement_type_label %>
        </span>
        <span class="text-gray-300">·</span>
        <span class="text-sm text-gray-500"><%= @agreement.entity_name %></span>
        <% if @agreement.overdue? %>
          <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-bold text-white bg-red-600">
            OVERDUE
          </span>
        <% end %>
      </div>
    </div>
    <div class="flex items-center gap-2">
      <span class="badge <%= @agreement.status_badge_class %> badge-lg"><%= @agreement.status_label %></span>
    </div>
  </div>

  <%# ── Stage Timeline — CafStage-aware ──────────────────────────────────── %>
  <div class="rounded-xl border border-gray-200 bg-white p-5 mb-4 overflow-x-auto">
    <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-5">Signing Pipeline</p>

    <% if @caf_stages.any? %>
      <%#
        Real stage nodes from DB.
        Prepend a synthetic "Draft" node (complete once submitted),
        append a synthetic "Complete" node (active/done when last stage done).
      %>
      <%
        days = @agreement.days_in_current_stage
        all_stages_done = @caf_stages.all? { |s| s.status == 'complete' }
      %>

      <%# Horizontal scroll rail on mobile %>
      <div class="flex items-start gap-0 min-w-max sm:min-w-0">

        <%# ── Synthetic DRAFT node (always complete once stages exist) %>
        <div class="flex flex-col items-center" style="min-width:80px;">
          <div class="w-8 h-8 rounded-full flex items-center justify-center text-white flex-shrink-0"
               style="background-color:#45AC34;">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m5 13 4 4L19 7"/></svg>
          </div>
          <p class="text-xs font-semibold text-gray-600 mt-2 text-center">Draft</p>
          <p class="text-xs text-green-600 mt-0.5">Done</p>
        </div>

        <% @caf_stages.each_with_index do |stage, idx| %>
          <%# Connector arrow %>
          <div class="flex items-center self-start mt-3.5 mx-1">
            <div class="w-6 h-0.5 bg-gray-200"></div>
            <svg class="w-3 h-3 text-gray-300 flex-shrink-0 -ml-1" fill="currentColor" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7"/></svg>
          </div>

          <%
            is_cp      = stage.name.include?('Counterparty')
            is_done    = stage.status == 'complete'
            is_active  = stage.status == 'active'
            is_pending = stage.status == 'pending'
            is_parallel = stage.routing == 'parallel'
            subs       = stage.caf_stage_submitters
            signed_ct  = subs.count { |css| css.submitter&.completed_at.present? }
            total_ct   = subs.size
          %>

          <div class="flex flex-col items-center" style="min-width:<%= is_parallel && total_ct > 0 ? '160px' : '100px' %>;">
            <%# Stage node %>
            <div class="w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0
                        <%= is_done ? 'text-white' : is_active ? 'text-white ring-2 ring-offset-2' : 'bg-gray-100 text-gray-400 border border-gray-200' %>"
                 style="<%= is_done ? 'background-color:#45AC34;' : is_active ? 'background-color:#162B3C; ring-color:#93c5fd;' : '' %>">
              <% if is_done %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m5 13 4 4L19 7"/></svg>
              <% elsif is_active %>
                <span class="w-2.5 h-2.5 rounded-full bg-white animate-pulse"></span>
              <% else %>
                <span class="text-xs font-bold"><%= idx + 2 %></span>
              <% end %>
            </div>

            <%# Stage label %>
            <%
              short_name = case stage.name
                           when /Internal/i    then 'Internal Approval'
                           when /Group Signer/i then 'Group Signer'
                           when /Counterparty/i then 'Counterparty'
                           else stage.name
                           end
            %>
            <p class="text-xs font-semibold mt-2 text-center leading-tight
                      <%= is_done ? 'text-gray-600' : is_active ? 'text-gray-900' : 'text-gray-400' %>">
              <%= short_name %>
            </p>

            <%# Status sub-label %>
            <% if is_done %>
              <p class="text-xs text-green-600 mt-0.5">Done</p>
            <% elsif is_active && is_parallel && total_ct > 0 %>
              <p class="text-xs mt-0.5 font-semibold
                        <%= signed_ct == total_ct ? 'text-green-600' : days > 9 ? 'text-red-600' : days > 5 ? 'text-amber-600' : 'text-gray-500' %>">
                <%= signed_ct %>/<%= total_ct %> signed
              </p>
            <% elsif is_active %>
              <p class="text-xs mt-0.5 <%= days > 9 ? 'text-red-600 font-semibold' : days > 5 ? 'text-amber-600' : 'text-gray-400' %>">
                <%= days == 0 ? 'Today' : "#{days}d waiting" %>
              </p>
            <% elsif is_pending %>
              <p class="text-xs text-gray-400 mt-0.5">Pending</p>
            <% end %>

            <%# Parallel Stage 0 — approver sub-grid %>
            <% if is_parallel && (is_active || is_done) && subs.any? %>
              <div class="mt-3 w-full space-y-1">
                <% subs.sort_by(&:position).each do |css| %>
                  <% signed = css.submitter&.completed_at.present? %>
                  <div class="flex items-center gap-1.5 px-2 py-1 rounded-md
                              <%= signed ? 'bg-green-50' : 'bg-gray-50' %>">
                    <% if signed %>
                      <svg class="w-3 h-3 flex-shrink-0 text-green-500" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m5 13 4 4L19 7"/></svg>
                    <% else %>
                      <span class="w-3 h-3 flex-shrink-0 rounded-full border border-gray-300 bg-white inline-block"></span>
                    <% end %>
                    <span class="text-xs <%= signed ? 'text-green-700 line-through' : 'text-gray-600' %> truncate leading-tight"
                          style="max-width:110px;" title="<%= css.submitter&.name %>">
                      <%= css.submitter&.name&.split&.first %>
                    </span>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>

        <%# Connector to Complete %>
        <div class="flex items-center self-start mt-3.5 mx-1">
          <div class="w-6 h-0.5 bg-gray-200"></div>
          <svg class="w-3 h-3 text-gray-300 flex-shrink-0 -ml-1" fill="currentColor" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7"/></svg>
        </div>

        <%# ── Synthetic COMPLETE node %>
        <div class="flex flex-col items-center" style="min-width:80px;">
          <div class="w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0
                      <%= all_stages_done ? 'text-white' : 'bg-gray-100 text-gray-400 border border-gray-200' %>"
               style="<%= all_stages_done ? 'background-color:#45AC34;' : '' %>">
            <% if all_stages_done %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m5 13 4 4L19 7"/></svg>
            <% else %>
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/></svg>
            <% end %>
          </div>
          <p class="text-xs font-semibold mt-2 text-center <%= all_stages_done ? 'text-gray-900' : 'text-gray-400' %>">Complete</p>
          <% if all_stages_done && @agreement.status_updated_at.present? %>
            <p class="text-xs text-green-600 mt-0.5"><%= @agreement.status_updated_at.strftime('%d %b') %></p>
          <% end %>
        </div>

      </div>

    <% else %>
      <%# Draft: no submission yet — simple 4-node skeleton %>
      <%
        tl_statuses = %w[draft pending_ig sent_counterparty complete]
        status_order = CafWorkflow::STATUSES - ['cancelled']
        current_idx  = status_order.index(@agreement.status) || 0
        days         = @agreement.days_in_current_stage
        tl_labels = { 'draft' => 'Draft', 'pending_ig' => 'Internal Review',
                      'sent_counterparty' => 'With Counterparty', 'complete' => 'Complete' }
      %>
      <div class="relative">
        <div class="hidden sm:block absolute top-4 left-8 right-8 h-0.5 bg-gray-200" aria-hidden="true"></div>
        <ol class="relative flex flex-col sm:flex-row items-start sm:items-start justify-between gap-6 sm:gap-0">
          <% tl_statuses.each_with_index do |stage_key, idx| %>
            <%
              s_idx      = status_order.index(stage_key) || 0
              is_done    = s_idx < current_idx
              is_current = s_idx == current_idx
            %>
            <li class="flex flex-row sm:flex-col items-center sm:items-center gap-3 sm:gap-2 flex-1 sm:text-center">
              <div class="relative z-10 flex-shrink-0 w-8 h-8 rounded-full flex items-center justify-center
                          <%= is_done ? 'text-white' : is_current ? 'text-white' : 'bg-gray-100 text-gray-400 border border-gray-200' %>"
                   style="<%= is_done ? 'background-color:#45AC34;' : is_current ? 'background-color:#162B3C;' : '' %>">
                <% if is_done %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m5 13 4 4L19 7"/></svg>
                <% else %>
                  <span class="text-xs font-bold"><%= idx + 1 %></span>
                <% end %>
              </div>
              <div class="flex flex-col sm:items-center">
                <p class="text-xs font-semibold <%= is_current ? 'text-gray-900' : is_done ? 'text-gray-600' : 'text-gray-400' %>">
                  <%= tl_labels[stage_key] %>
                </p>
                <p class="text-xs mt-0.5 <%= is_done ? 'text-green-600' : 'text-gray-400' %>">
                  <%= is_done ? 'Done' : (is_current ? 'Current' : 'Pending') %>
                </p>
              </div>
            </li>
            <% unless idx == tl_statuses.length - 1 %>
              <li class="sm:hidden ml-4 w-0.5 h-4 bg-gray-200" aria-hidden="true"></li>
            <% end %>
          <% end %>
        </ol>
      </div>
    <% end %>
  </div>

  <%# ── Entity + Relationship card ────────────────────────────────────────── %>
  <div class="rounded-xl border border-gray-200 bg-white px-5 py-3 mb-4 flex items-center gap-3 flex-wrap">
    <%# Entity badge %>
    <% if @entity_record %>
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-md text-xs font-semibold text-white"
            style="background-color:#162B3C;">
        <%= @entity_record.short_name || @entity_record.name %>
      </span>
    <% elsif @agreement.entity.present? %>
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-md text-xs font-semibold text-white"
            style="background-color:#162B3C;">
        <%= @agreement.entity.to_s.upcase %>
      </span>
    <% end %>

    <%# Customer / Supplier chip %>
    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold
                 <%= @agreement.commercial_supplier? ? 'bg-amber-100 text-amber-700' : 'bg-blue-100 text-blue-700' %>">
      <%= @agreement.commercial_supplier? ? '↑ Supplier' : '↓ Customer' %>
    </span>

    <%# Counterparty name %>
    <% if @agreement.contracting_party.present? %>
      <span class="text-sm text-gray-700 font-medium"><%= @agreement.contracting_party %></span>
    <% end %>

    <%# Separator %>
    <span class="text-gray-200 hidden sm:inline">|</span>

    <%# Days in current stage %>
    <% unless @agreement.draft? || @agreement.complete? || @agreement.cancelled? %>
      <%
        d = @agreement.days_in_current_stage
        day_cls = d > 9 ? 'text-red-600 font-semibold' : d > 5 ? 'text-amber-600 font-semibold' : 'text-gray-500'
      %>
      <span class="text-xs <%= day_cls %>">
        <%= d == 0 ? 'In progress today' : "#{d} #{d == 1 ? 'day' : 'days'} in current stage" %>
      </span>
    <% end %>
  </div>

  <%# ── Current Status Card ─────────────────────────────────────────────────── %>
  <% if @current_holder %>
    <%
      days_held = @current_holder[:days].to_i
      is_overdue   = days_held > 9
      is_warn      = days_held > 5
    %>
    <div class="rounded-xl border mb-4 overflow-hidden
                <%= is_overdue ? 'border-red-200 bg-red-50' : is_warn ? 'border-amber-200 bg-amber-50' : 'border-gray-200 bg-white' %>">
      <div class="px-5 py-3 border-b flex items-center gap-2
                  <%= is_overdue ? 'border-red-200 bg-red-100/50' : is_warn ? 'border-amber-200 bg-amber-100/50' : 'border-gray-100 bg-gray-50' %>">
        <% if is_overdue %>
          <svg class="w-4 h-4 text-red-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          <span class="text-sm font-semibold text-red-700">Significantly Overdue</span>
        <% elsif is_warn %>
          <svg class="w-4 h-4 text-amber-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          <span class="text-sm font-semibold text-amber-700">Overdue — Consider Sending a Reminder</span>
        <% else %>
          <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          <span class="text-sm font-semibold text-gray-700">Currently With</span>
        <% end %>
      </div>
      <div class="px-5 py-4">
        <div class="flex items-start justify-between gap-4">
          <div>
            <p class="font-semibold text-gray-900"><%= @current_holder[:name] %></p>
            <p class="text-sm text-gray-500 mt-0.5"><%= @current_holder[:role] %></p>
            <% if @current_holder[:invited_at].present? %>
              <p class="text-xs text-gray-400 mt-1">
                Invited <%= @current_holder[:invited_at].strftime('%d %b %Y at %H:%M') %>
              </p>
            <% end %>
            <% if days_held > 0 %>
              <p class="text-sm font-semibold mt-2
                        <%= is_overdue ? 'text-red-600' : is_warn ? 'text-amber-600' : 'text-gray-700' %>">
                Waiting <%= days_held %> <%= days_held == 1 ? 'day' : 'days' %>
              </p>
            <% end %>
          </div>
          <% if @agreement.sent_counterparty? && @agreement.counterparty_email.present? %>
            <div class="text-right shrink-0">
              <p class="text-xs text-gray-400 mb-1">Signing link</p>
              <% cp_sub = @agreement.caf_submission&.submitters&.find { |s| s.email&.strip&.downcase == @agreement.counterparty_email.strip.downcase } %>
              <% if cp_sub&.slug.present? %>
                <input readonly value="<%= submit_form_url(cp_sub.slug) %>"
                       class="text-xs border rounded px-2 py-1 bg-gray-50 text-gray-600 w-52 truncate"
                       title="Counterparty signing link — copy and share if needed">
              <% else %>
                <p class="text-xs text-gray-400 italic">Link not available</p>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <%# ── Completion card ─────────────────────────────────────────────────────── %>
  <% if @agreement.complete? %>
    <div class="rounded-xl border border-green-200 bg-green-50 px-5 py-4 mb-4 flex items-center gap-3">
      <div class="w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0" style="background-color:#45AC34;">
        <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m5 13 4 4L19 7"/></svg>
      </div>
      <div>
        <p class="font-semibold text-green-800">Signed by all parties</p>
        <% if @agreement.status_updated_at.present? %>
          <p class="text-sm text-green-600"><%= @agreement.status_updated_at.strftime('%d %B %Y') %></p>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# ── Signing Journey (live status, Turbo Frame polling) ─────────────────── %>
  <div class="rounded-xl border border-gray-200 bg-white mb-4 overflow-hidden">
    <div class="px-5 py-3 border-b border-gray-100 flex items-center gap-2" style="background-color:#f8fafc;">
      <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
        <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
      </svg>
      <span class="text-sm font-semibold text-gray-700">Signing journey</span>
      <% if @agreement.pending_ig? || @agreement.sent_counterparty? %>
        <span class="ml-auto text-xs text-gray-400 flex items-center gap-1">
          <span class="w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse inline-block"></span>
          Live
        </span>
      <% end %>
    </div>
    <div class="px-5 py-5 overflow-x-auto">
      <turbo-frame id="signing-journey-<%= @agreement.id %>"
                   src="<%= signing_journey_agreement_path(@agreement) %>">
        <%= render 'signing_journey',
                   agreement:              @agreement,
                   signatories:            @signatories,
                   mode:                   :live,
                   submitter_statuses:     @submitter_statuses,
                   counterparty_signatory: @counterparty_signatory %>
      </turbo-frame>
    </div>
  </div>

  <%# ── Agreement Details ────────────────────────────────────────────────────── %>
  <div class="rounded-xl border border-gray-200 bg-white mb-4 overflow-hidden">
    <div class="px-5 py-3 border-b border-gray-100" style="background-color:#f8fafc;">
      <p class="text-sm font-semibold text-gray-700">Details</p>
    </div>
    <div class="px-5 py-4 grid grid-cols-2 gap-x-6 gap-y-3 text-sm">
      <div>
        <p class="text-xs text-gray-400 mb-0.5">Requestor</p>
        <p class="font-medium text-gray-900"><%= @agreement.requestor_name %></p>
      </div>
      <div>
        <p class="text-xs text-gray-400 mb-0.5">Created</p>
        <p class="font-medium text-gray-900"><%= @agreement.created_at.strftime('%d %b %Y') %></p>
      </div>
      <% if @agreement.mandate_description.present? %>
        <div class="col-span-2">
          <p class="text-xs text-gray-400 mb-0.5">Mandate</p>
          <p class="text-gray-700"><%= @agreement.mandate_description %></p>
        </div>
      <% end %>
    </div>
  </div>

  <%# ── Actions ──────────────────────────────────────────────────────────────── %>
  <div class="flex justify-end gap-3">
    <% if @agreement.draft? %>
      <%= link_to review_agreement_path(@agreement),
                  class: 'px-5 py-2.5 rounded-lg text-sm font-semibold text-white',
                  style: 'background-color:#162B3C;' do %>
        Continue to Review →
      <% end %>
    <% end %>

    <% if @agreement.pending_ig? || @agreement.sent_counterparty? %>
      <%= button_to remind_agreement_path(@agreement),
                    method: :post,
                    data: { confirm: 'Send an immediate reminder to all unsigned signatories?' },
                    class: 'px-4 py-2.5 rounded-lg text-sm font-semibold border border-amber-400 text-amber-700 bg-amber-50 hover:bg-amber-100 cursor-pointer' do %>
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0 1 18 14.158V11a6.002 6.002 0 0 0-4-5.659V5a2 2 0 1 0-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 1 1-6 0v-1m6 0H9"/>
          </svg>
          Remind All
        </span>
      <% end %>
    <% end %>
  </div>

</div>

<%# ── Turbo Frame polling (active workflows only) ──────────────────────────── %>
<% if @agreement.pending_ig? || @agreement.sent_counterparty? %>
  <script nonce="<%= content_security_policy_nonce %>">
  (function () {
    var frameId = 'signing-journey-<%= @agreement.id %>';
    var timer;

    function startPolling() {
      var frame = document.getElementById(frameId);
      if (!frame) return;
      timer = setInterval(function () {
        if (!document.hidden && frame.isConnected) {
          frame.reload();
        }
      }, 30000); // 30 s
    }

    function stopPolling() {
      clearInterval(timer);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', startPolling);
    } else {
      startPolling();
    }

    document.addEventListener('turbo:before-cache', stopPolling, { once: true });
  })();
  </script>
<% end %>
