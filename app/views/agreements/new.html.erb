<% content_for :title, 'New Agreement' %>

<div class="max-w-4xl mx-auto px-4 py-8">

  <%# ── Step indicator ──────────────────────────────────────────────────── %>
  <div class="flex items-center mb-8">
    <% [['1','Agreement Details'],['2','Upload Document'],['3','Review & Send']].each_with_index do |(n,label),i| %>
      <div class="flex items-center gap-2">
        <div class="w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold shrink-0
             <%= @step.to_i >= n.to_i ? 'text-white' : 'text-gray-400 border-2 border-gray-200 bg-white' %>"
             style="<%= @step.to_i >= n.to_i ? 'background-color:#1a2332;' : '' %>">
          <%= n %>
        </div>
        <span class="text-sm whitespace-nowrap
             <%= @step.to_i == n.to_i ? 'font-semibold text-gray-900' : 'text-gray-400' %>">
          <%= label %>
        </span>
      </div>
      <% if i < 2 %><div class="flex-1 h-px bg-gray-200 mx-3 min-w-[24px]"></div><% end %>
    <% end %>
  </div>

  <h1 class="text-2xl font-bold text-gray-900 mb-1">New Agreement</h1>
  <p class="text-sm text-gray-500 mb-6">Fill in the details below. Signatories are assigned automatically based on agreement type and entity.</p>

  <%= form_with scope: :agreement, url: agreements_path, method: :post,
                data: { controller: 'agreement-wizard' } do |f| %>

    <% if @agreement.errors.any? %>
      <div class="mb-4 p-4 rounded-lg bg-red-50 border border-red-200 text-sm text-red-700">
        <p class="font-semibold mb-1">Please fix the following:</p>
        <ul class="list-disc list-inside space-y-0.5">
          <% @agreement.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

      <%# ── LEFT: agreement + entity + mandate ────────────────────────────── %>
      <div class="md:col-span-2 space-y-5">

        <%# Agreement type %>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">
            Agreement Type <span class="text-red-500">*</span>
          </label>
          <%= f.select :agreement_type,
            CafWorkflow::AGREEMENT_TYPES.map { |k,v| [v, k] },
            { include_blank: '— Select type —' },
            class: 'w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent',
            required: true %>
        </div>

        <%# IG Entity %>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">
            IG Entity <span class="text-red-500">*</span>
          </label>
          <%= f.select :entity,
            IgSignatories::ENTITIES.map { |k,v| [v[:name], k.to_s] },
            { include_blank: '— Select entity —' },
            class: 'w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent',
            required: true %>
          <p class="mt-1 text-xs text-gray-400">Which IG business unit / company is entering this agreement?</p>
        </div>

        <%# Counterparty contact row %>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">Contact Name</label>
            <%= f.text_field :counterparty_name,
              data: { 'agreement-wizard-target': 'contactName' },
              class: 'w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500',
              placeholder: 'John Smith' %>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">Contact Email</label>
            <%= f.email_field :counterparty_email,
              data: { 'agreement-wizard-target': 'contactEmail' },
              class: 'w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500',
              placeholder: 'john@company.co.za' %>
          </div>
        </div>

        <%# Mandate / description %>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Mandate &amp; Purpose</label>
          <%= f.text_area :mandate_description, rows: 3,
            class: 'w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none',
            placeholder: 'Briefly describe what this agreement covers and why it is needed.' %>
        </div>

        <%# Requestor hidden %>
        <%= f.hidden_field :requestor_name,  value: @agreement.requestor_name %>
        <%= f.hidden_field :requestor_email, value: @agreement.requestor_email %>

      </div>

      <%# ── RIGHT: counterparty company ───────────────────────────────────── %>
      <div class="md:col-span-1">
        <div class="rounded-xl border border-gray-200 bg-gray-50 p-4 h-full">
          <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">Counterparty Company</p>

          <%# Search existing companies %>
          <div class="relative mb-3">
            <input type="text"
                   id="company_search"
                   placeholder="Search companies..."
                   autocomplete="off"
                   data-agreement-wizard-target="companySearch"
                   data-action="input->agreement-wizard#searchCompanies"
                   class="w-full rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm pl-8 focus:outline-none focus:ring-2 focus:ring-blue-500">
            <svg class="absolute left-2.5 top-2.5 w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
            </svg>
          </div>

          <%# Search results dropdown %>
          <div id="company_results"
               data-agreement-wizard-target="companyResults"
               class="hidden space-y-1.5 mb-3 max-h-48 overflow-y-auto">
          </div>

          <%# Selected company display %>
          <div id="selected_company"
               data-agreement-wizard-target="selectedCompany"
               class="hidden rounded-lg border border-blue-200 bg-blue-50 p-3 mb-3">
            <div class="flex items-start justify-between gap-2">
              <div>
                <p class="text-sm font-semibold text-gray-900" data-agreement-wizard-target="selectedName"></p>
                <p class="text-xs text-gray-500 mt-0.5" data-agreement-wizard-target="selectedDomain"></p>
              </div>
              <button type="button" data-action="click->agreement-wizard#clearCompany"
                      class="text-gray-400 hover:text-gray-600 shrink-0">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M18 6 6 18M6 6l12 12"/>
                </svg>
              </button>
            </div>
          </div>

          <%= f.hidden_field :company_id, data: { 'agreement-wizard-target': 'companyIdInput' } %>

          <%# Divider %>
          <div class="flex items-center gap-2 my-3">
            <div class="flex-1 h-px bg-gray-200"></div>
            <span class="text-xs text-gray-400">or</span>
            <div class="flex-1 h-px bg-gray-200"></div>
          </div>

          <%# Toggle new company form %>
          <button type="button"
                  data-action="click->agreement-wizard#toggleNewCompany"
                  data-agreement-wizard-target="addNewToggle"
                  class="w-full flex items-center justify-center gap-1.5 rounded-lg border border-dashed border-gray-300 px-3 py-2 text-xs font-medium text-gray-500 hover:border-gray-400 hover:text-gray-700 transition-colors">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M12 5v14M5 12h14"/>
            </svg>
            Add new company
          </button>

          <%# New company inline form (hidden initially) %>
          <div id="new_company_form"
               data-agreement-wizard-target="newCompanyForm"
               class="hidden mt-3 space-y-2">
            <input type="text" name="new_company_name"
                   placeholder="Company name *"
                   class="w-full rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
            <input type="text" name="new_company_contact_name"
                   placeholder="Contact name"
                   data-agreement-wizard-target="newContactName"
                   class="w-full rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
            <input type="email" name="new_company_contact_email"
                   placeholder="Contact email"
                   data-agreement-wizard-target="newContactEmail"
                   class="w-full rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
            <input type="text" name="new_company_domain"
                   placeholder="Domain (e.g. acme.co.za)"
                   class="w-full rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
            <p class="text-xs text-gray-400">This company will be saved to your directory.</p>
          </div>

        </div>
      </div>

    </div><%# end grid %>

    <div class="mt-8 flex items-center justify-between pt-6 border-t border-gray-200">
      <%= link_to agreements_path, class: 'text-sm text-gray-500 hover:text-gray-700' do %>
        ← Cancel
      <% end %>
      <%= f.submit 'Continue to Upload →',
            class: 'px-6 py-2.5 rounded-lg text-sm font-semibold text-white cursor-pointer transition-colors',
            style: 'background-color:#1a2332;' %>
    </div>

  <% end %>

</div>

<%# Stimulus controller for company search + form toggling %>
<script>
(function() {
  const SEARCH_URL = '<%= search_companies_agreements_path(format: :json) %>';

  function initWizard() {
    const el = document.querySelector('[data-controller="agreement-wizard"]');
    if (!el) return;

    const $  = (sel, ctx = el) => ctx.querySelector(sel);
    const $$ = (sel, ctx = el) => [...ctx.querySelectorAll(sel)];

    const searchInput    = $('[data-agreement-wizard-target="companySearch"]');
    const resultsBox     = $('[data-agreement-wizard-target="companyResults"]');
    const selectedBox    = $('[data-agreement-wizard-target="selectedCompany"]');
    const selectedName   = $('[data-agreement-wizard-target="selectedName"]');
    const selectedDomain = $('[data-agreement-wizard-target="selectedDomain"]');
    const companyIdInput = $('[data-agreement-wizard-target="companyIdInput"]');
    const contactName    = $('[data-agreement-wizard-target="contactName"]');
    const contactEmail   = $('[data-agreement-wizard-target="contactEmail"]');
    const addNewToggle   = $('[data-agreement-wizard-target="addNewToggle"]');
    const newCompanyForm = $('[data-agreement-wizard-target="newCompanyForm"]');
    const newContactName = $('[data-agreement-wizard-target="newContactName"]');
    const newContactEmail= $('[data-agreement-wizard-target="newContactEmail"]');

    let debounceTimer;

    searchInput && searchInput.addEventListener('input', function() {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => {
        const q = this.value.trim();
        if (q.length < 1) { resultsBox.classList.add('hidden'); return; }
        fetch(SEARCH_URL + '?q=' + encodeURIComponent(q), { headers: { Accept: 'application/json' } })
          .then(r => r.json())
          .then(companies => {
            resultsBox.innerHTML = '';
            if (!companies.length) {
              resultsBox.innerHTML = '<p class="text-xs text-gray-400 px-1 py-2">No matches — add below</p>';
            } else {
              companies.forEach(c => {
                const btn = document.createElement('button');
                btn.type = 'button';
                btn.className = 'w-full text-left rounded-lg bg-white border border-gray-200 px-3 py-2 text-sm hover:border-blue-400 hover:bg-blue-50 transition-colors';
                btn.innerHTML = `<span class="font-medium text-gray-900">${c.name}</span>${c.domain ? '<span class="text-xs text-gray-400 ml-1.5">'+c.domain+'</span>' : ''}${c.contact_name ? '<br><span class="text-xs text-gray-500">'+c.contact_name+'</span>' : ''}`;
                btn.addEventListener('click', () => selectCompany(c));
                resultsBox.appendChild(btn);
              });
            }
            resultsBox.classList.remove('hidden');
          });
      }, 250);
    });

    function selectCompany(c) {
      companyIdInput.value    = c.id;
      selectedName.textContent  = c.name;
      selectedDomain.textContent = c.domain || '';
      selectedBox.classList.remove('hidden');
      resultsBox.classList.add('hidden');
      searchInput.value = '';
      if (contactName  && !contactName.value  && c.contact_name)  contactName.value  = c.contact_name;
      if (contactEmail && !contactEmail.value && c.contact_email) contactEmail.value = c.contact_email;
    }

    // Clear selected company
    el.addEventListener('click', function(e) {
      if (e.target.closest('[data-action="click->agreement-wizard#clearCompany"]')) {
        companyIdInput.value = '';
        selectedBox.classList.add('hidden');
      }
      if (e.target.closest('[data-action="click->agreement-wizard#toggleNewCompany"]')) {
        newCompanyForm.classList.toggle('hidden');
        addNewToggle.textContent = newCompanyForm.classList.contains('hidden') ? '+ Add new company' : '− Hide form';
        // Mirror contact details into main form
        newContactName  && (newContactName.addEventListener('input',  () => { if (contactName)  contactName.value  = newContactName.value; }));
        newContactEmail && (newContactEmail.addEventListener('input', () => { if (contactEmail) contactEmail.value = newContactEmail.value; }));
      }
    });

    // Close dropdown on outside click
    document.addEventListener('click', function(e) {
      if (!el.contains(e.target)) resultsBox.classList.add('hidden');
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initWizard);
  } else {
    initWizard();
  }
})();
</script>
