<% content_for :title, 'Agreements' %>

<%# IGSIGN Staff walkthrough — shown on first visit or ?tour=true %>
<% if params[:tour] == 'true' || (user_signed_in? && current_user.walkthrough_completed_at.nil?) %>
  <%= render 'agreements/staff_walkthrough' %>
<% end %>

<div class="max-w-6xl mx-auto px-4 pt-6 pb-2">
  <%# ── Welcome Hero ────────────────────────────────────────────────────────── %>
  <%
    hour = Time.current.in_time_zone('Africa/Johannesburg').hour
    greeting = hour < 12 ? 'Good morning' : hour < 17 ? 'Good afternoon' : 'Good evening'
    first_name = current_user.first_name.presence || current_user.full_name.split.first
    active_count  = @stats[:active]
    pending_count = @stats.fetch(:draft, 0)
    taglines = [
      "Let's close some deals.",
      "Your pipeline is waiting.",
      "Time to make it official.",
      "Deals don't sign themselves.",
      "Move it forward today."
    ]
    tagline = taglines[Date.today.yday % taglines.length]
  %>
  <div class="rounded-2xl mb-6 overflow-hidden relative" style="background:linear-gradient(135deg,#0B1722 0%,#162B3C 60%,#1a3a4a 100%);">
    <%# Subtle IG hex watermark %>
    <div class="absolute inset-0 opacity-5 pointer-events-none" style="background-image:url(\"data:image/svg+xml,%3Csvg width='60' height='70' viewBox='0 0 60 70' xmlns='http://www.w3.org/2000/svg'%3E%3Cpolygon points='30,2 58,17 58,53 30,68 2,53 2,17' fill='none' stroke='white' stroke-width='1.5'/%3E%3C/svg%3E\");background-size:80px 80px;"></div>
    <div class="relative px-8 py-7 flex items-center justify-between gap-6 flex-wrap">
      <div>
        <p class="text-sm font-medium mb-1" style="color:#00C853;">IGSIGN &mdash; Ignition Group</p>
        <h2 class="text-2xl font-bold text-white mb-1"><%= greeting %>, <%= first_name %>.</h2>
        <p class="text-base font-medium" style="color:#94a3b8;"><%= tagline %></p>
      </div>
      <div class="flex items-center gap-4 flex-wrap">
        <% if active_count > 0 %>
          <div class="text-center px-5 py-3 rounded-xl" style="background:rgba(255,255,255,0.07);">
            <p class="text-2xl font-bold text-white"><%= active_count %></p>
            <p class="text-xs font-medium" style="color:#94a3b8;">Active</p>
          </div>
        <% end %>
        <% if @stats[:overdue] > 0 %>
          <div class="text-center px-5 py-3 rounded-xl" style="background:rgba(220,38,38,0.15);border:1px solid rgba(220,38,38,0.3);">
            <p class="text-2xl font-bold text-red-400"><%= @stats[:overdue] %></p>
            <p class="text-xs font-medium text-red-400">Overdue</p>
          </div>
        <% end %>
        <%= link_to new_agreement_path,
                    class: 'flex items-center gap-2 px-5 py-3 rounded-xl text-sm font-bold transition-all hover:opacity-90',
                    style: 'background-color:#00C853;color:#0B1722;' do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path d="M12 5v14M5 12h14"/>
          </svg>
          New Agreement
        <% end %>
      </div>
    </div>
  </div>
</div>

<div class="max-w-6xl mx-auto px-4 pb-8">


  <%# ── Stats bar ────────────────────────────────────────────────────────────── %>
  <div class="grid grid-cols-2 sm:grid-cols-5 gap-3 mb-6">
    <% [
      { label: 'Total',    count: @stats[:total],    color: '#1a2332', icon: nil },
      { label: 'Draft',    count: @stats[:draft],    color: '#9ca3af', icon: nil },
      { label: 'Active',   count: @stats[:active],   color: '#d97706', icon: nil },
      { label: 'Complete', count: @stats[:complete], color: '#16a34a', icon: nil }
    ].each do |s| %>
      <div class="rounded-xl border border-gray-200 bg-white px-4 py-3">
        <p class="text-2xl font-bold" style="color:<%= s[:color] %>;"><%= s[:count] %></p>
        <p class="text-xs text-gray-400 mt-0.5"><%= s[:label] %></p>
      </div>
    <% end %>
    <%# Overdue counter — red when non-zero %>
    <div class="rounded-xl border px-4 py-3
                <%= @stats[:overdue] > 0 ? 'border-red-200 bg-red-50' : 'border-gray-200 bg-white' %>">
      <p class="text-2xl font-bold <%= @stats[:overdue] > 0 ? 'text-red-600' : 'text-gray-300' %>">
        <%= @stats[:overdue] %>
      </p>
      <p class="text-xs mt-0.5 <%= @stats[:overdue] > 0 ? 'text-red-500 font-semibold' : 'text-gray-400' %>">
        Overdue
      </p>
    </div>
  </div>

  <%# ── Customer / Supplier / NDA filter chips ───────────────────────────── %>
  <%
    cur_rel   = params[:relationship].to_s
    cur_atype = params[:agreement_type].to_s
  %>
  <div class="flex items-center gap-2 mb-3 flex-wrap">
    <span class="text-xs text-gray-400 font-medium mr-1">Filter:</span>
    <% [
      ['All',      nil,        nil   ],
      ['Customer', 'customer', nil   ],
      ['Supplier', 'supplier', nil   ],
      ['NDA',      nil,        'nda' ]
    ].each do |lbl, rel, atype| %>
      <%
        chip_on = rel.to_s == cur_rel && atype.to_s == cur_atype
        chip_on = cur_rel.blank? && cur_atype.blank? if rel.nil? && atype.nil?
      %>
      <%= link_to lbl,
                  agreements_path(status: params[:status].presence,
                                  relationship: rel,
                                  agreement_type: atype),
                  class: "px-3 py-1 rounded-full text-xs font-semibold transition-colors #{chip_on ? '' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'}",
                  style: chip_on ? 'background-color:#00C853; color:#fff;' : '' %>
    <% end %>
  </div>

  <%# ── Filter tabs + view toggle ───────────────────────────────────────────── %>
  <div class="flex items-center justify-between mb-4 border-b border-gray-200">
    <div class="flex items-center gap-1">
      <% [['', 'All'], ['draft', 'Draft'], ['pending_ig', 'Pending IG'],
          ['sent_counterparty', 'With Counterparty'], ['complete', 'Complete']].each do |val, label| %>
        <% is_active = params[:status].to_s == val %>
        <%= link_to agreements_path(status: val.presence,
                                    relationship: params[:relationship].presence,
                                    agreement_type: params[:agreement_type].presence),
                    class: "px-3 py-2 text-sm font-medium border-b-2 transition-colors -mb-px
            #{is_active ? 'border-gray-900 text-gray-900' : 'border-transparent text-gray-400 hover:text-gray-700'}" do %>
          <%= label %>
        <% end %>
      <% end %>
    </div>

    <%# Table / Pipeline toggle %>
    <div class="flex items-center gap-1 mb-px" id="ig-view-toggle">
      <button id="ig-btn-table"
              onclick="igSetView('table')"
              class="p-1.5 rounded border text-gray-400 hover:text-gray-700 transition-colors"
              title="Table view" aria-label="Table view">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M3 10h18M3 14h18M3 6h18M3 18h18"/>
        </svg>
      </button>
      <button id="ig-btn-pipeline"
              onclick="igSetView('pipeline')"
              class="p-1.5 rounded border text-gray-400 hover:text-gray-700 transition-colors"
              title="Pipeline view" aria-label="Pipeline view">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <rect x="3" y="3" width="5" height="18" rx="1"/><rect x="10" y="3" width="5" height="18" rx="1"/><rect x="17" y="3" width="4" height="18" rx="1"/>
        </svg>
      </button>
    </div>
  </div>

  <% if @agreements.any? %>

    <%# ── TABLE VIEW ────────────────────────────────────────────────────────── %>
    <div id="ig-view-table">
      <div class="rounded-xl border border-gray-200 bg-white overflow-hidden">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-200" style="background-color:#f8fafc;">
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Type</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Parties</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Status</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide hidden md:table-cell">Holder</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide hidden md:table-cell">Days</th>
              <th class="px-4 py-3"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% @agreements.each do |a| %>
              <%
                a_days    = a.days_in_current_stage
                a_overdue = a.overdue?
                a_warn    = a.slightly_overdue?
                a_holder  = a.current_holder_name
              %>
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="px-4 py-3">
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold text-white"
                        style="background-color:#1a2332;">
                    <%= a.agreement_type_label.split(' — ').first %>
                  </span>
                </td>
                <td class="px-4 py-3">
                  <%
                    ig_role = case a.agreement_type
                              when 'nda' then 'NDA Party'
                              else a.commercial_supplier? ? 'Service Receiver' : 'Service Provider'
                              end
                    cp_role = case a.agreement_type
                              when 'nda' then 'NDA Party'
                              else a.commercial_supplier? ? 'Service Provider' : 'Service Receiver'
                              end
                  %>
                  <div class="flex items-start gap-4">
                    <div class="min-w-0">
                      <p class="text-xs font-bold uppercase tracking-wide mb-0.5" style="color:#00C853;font-size:10px;"><%= ig_role %></p>
                      <p class="text-sm font-semibold text-gray-900 truncate"><%= a.entity_name %></p>
                    </div>
                    <div class="shrink-0 self-center text-gray-300 text-lg leading-none">↔</div>
                    <div class="min-w-0">
                      <p class="text-xs font-bold uppercase tracking-wide mb-0.5" style="color:#6b7280;font-size:10px;"><%= cp_role %></p>
                      <p class="text-sm font-medium truncate" style="color:#0B1722;">
                        <%= a.contracting_party.presence || '(pending)' %>
                      </p>
                    </div>
                  </div>
                </td>
                <td class="px-4 py-3">
                  <div class="flex items-center gap-1.5">
                    <span class="badge <%= a.status_badge_class %> badge-sm whitespace-nowrap">
                      <%= a.status_label %>
                    </span>
                    <% if a_overdue %>
                      <span class="inline-flex px-1.5 py-0.5 rounded text-xs font-bold text-white bg-red-600">!</span>
                    <% end %>
                  </div>
                </td>
                <td class="px-4 py-3 hidden md:table-cell text-gray-600 text-xs">
                  <%= a_holder.presence || '—' %>
                </td>
                <td class="px-4 py-3 hidden md:table-cell text-xs font-semibold
                           <%= a_overdue ? 'text-red-600' : a_warn ? 'text-amber-600' : 'text-gray-400' %>">
                  <%= a.draft? || a.complete? ? '—' : "#{a_days}d" %>
                </td>
                <td class="px-4 py-3 text-right">
                  <% if a.draft? %>
                    <% draft_step = a.next_draft_step %>
                    <div class="flex items-center gap-3 justify-end">
                    <%= link_to 'Continue →',
                                (draft_step.present? ? send(:"#{draft_step}_agreement_path", a) : agreement_path(a)),
                                class: 'text-xs font-medium text-blue-600 hover:text-blue-800' %>
                    <%= button_to '✕', agreement_path(a), method: :delete,
                                  form: { data: { turbo_confirm: 'Delete this draft agreement? This cannot be undone.' } },
                                  class: 'text-xs font-medium text-red-400 hover:text-red-600 bg-transparent border-0 cursor-pointer p-0' %>
                    </div>
                  <% elsif a_overdue && (a.pending_ig? || a.sent_counterparty?) %>
                    <%= button_to remind_agreement_path(a), method: :post,
                                  class: 'text-xs font-semibold text-red-600 hover:text-red-800 underline bg-transparent border-0 cursor-pointer p-0' do %>
                      Remind →
                    <% end %>
                  <% else %>
                    <%= link_to 'View →', agreement_path(a),
                                class: 'text-xs font-medium text-blue-600 hover:text-blue-800' %>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <%# ── PIPELINE VIEW ──────────────────────────────────────────────────────── %>
    <div id="ig-view-pipeline" class="hidden">
      <%
        pipeline_cols = [
          { key: 'draft',             label: 'Draft',            color: '#9ca3af' },
          { key: 'pending_ig',        label: 'IG Approval',      color: '#d97706' },
          { key: 'group_signer',      label: 'Group Signer',     color: '#8b5cf6' },
          { key: 'sent_counterparty', label: 'With Counterparty', color: '#3b82f6' },
          { key: 'complete',          label: 'Complete',          color: '#16a34a' }
        ]

        # Group all loaded agreements by status.
        # pending_ig is split: if the active stage is a Group Signer stage → 'group_signer' bucket.
        grouped = @agreements.group_by do |a|
          case a.status
          when 'ig_complete' then 'group_signer'
          when 'pending_ig'
            active_st = a.caf_submission&.caf_stages&.detect { |s| s.status == 'active' }
            active_st&.name&.include?('Group Signer') ? 'group_signer' : 'pending_ig'
          else a.status
          end
        end
      %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-3">
        <% pipeline_cols.each do |col| %>
          <div class="rounded-xl border border-gray-200 bg-gray-50 overflow-hidden">
            <%# Column header %>
            <div class="px-3 py-2.5 border-b border-gray-200 flex items-center justify-between" style="background-color:#f8fafc;">
              <div class="flex items-center gap-2">
                <span class="w-2 h-2 rounded-full flex-shrink-0" style="background-color:<%= col[:color] %>;"></span>
                <span class="text-xs font-semibold text-gray-700 leading-tight"><%= col[:label] %></span>
              </div>
              <span class="text-xs font-bold text-gray-400 flex-shrink-0"><%= (grouped[col[:key]] || []).size %></span>
            </div>

            <%# Cards %>
            <div class="p-2 flex flex-col gap-2 min-h-[8rem]">
              <% (grouped[col[:key]] || []).sort_by { |a| -(a.days_in_current_stage) }.each do |a| %>
                <%
                  a_days   = a.days_in_current_stage
                  a_od     = a.overdue?
                  a_warn   = a.slightly_overdue?
                  a_holder = a.current_holder_name
                  a_entity = a.entity.to_s.split('_').first.to_s.upcase
                %>
                <div class="rounded-lg bg-white border shadow-sm px-3 py-2.5
                            <%= a_od ? 'border-red-200' : a_warn ? 'border-amber-200' : 'border-gray-200' %>">
                  <%# Top row: type + entity + overdue %>
                  <div class="flex items-center gap-1 flex-wrap mb-1">
                    <span class="inline-flex px-1.5 py-0.5 rounded text-xs font-semibold text-white"
                          style="background-color:#1a2332;">
                      <%= a.agreement_type_label.split(' — ').first %>
                    </span>
                    <% if a_entity.present? %>
                      <span class="inline-flex px-1.5 py-0.5 rounded text-xs font-semibold"
                            style="background-color:#e8f0fe; color:#1a2332;">
                        <%= a_entity %>
                      </span>
                    <% end %>
                    <span class="inline-flex px-1.5 py-0.5 rounded text-xs font-semibold
                                 <%= a.commercial_supplier? ? 'text-amber-700 bg-amber-100' : 'text-blue-700 bg-blue-100' %>">
                      <%= a.commercial_supplier? ? 'Supplier' : 'Customer' %>
                    </span>
                    <% if a_od %>
                      <span class="inline-flex px-1.5 py-0.5 rounded text-xs font-bold text-white bg-red-600 whitespace-nowrap ml-auto">!</span>
                    <% end %>
                  </div>
                  <%
                    card_ig_role = case a.agreement_type
                                   when 'nda' then 'NDA Party'
                                   else a.commercial_supplier? ? 'Service Receiver' : 'Service Provider'
                                   end
                  %>
                  <p class="text-xs font-semibold truncate leading-tight" style="color:#00C853;">
                    <%= a.entity_name %>
                  </p>
                  <p class="text-xs leading-tight" style="color:#00C853;opacity:0.75;">
                    <%= card_ig_role %>
                  </p>
                  <p class="text-sm font-semibold leading-tight truncate mt-0.5" style="color:#0B1722;">
                    <%= a.contracting_party.presence || '(counterparty pending)' %>
                  </p>
                  <% if a_holder.present? && !a.draft? && !a.complete? %>
                    <p class="text-xs text-gray-500 mt-0.5 truncate">↳ <%= a_holder %></p>
                  <% end %>
                  <div class="flex items-center justify-between mt-2">
                    <% unless a.draft? || a.complete? %>
                      <span class="text-xs font-semibold <%= a_od ? 'text-red-600' : a_warn ? 'text-amber-600' : 'text-gray-400' %>">
                        <%= a_days %>d
                      </span>
                    <% else %>
                      <span></span>
                    <% end %>
                    <% if a_od && (a.pending_ig? || a.sent_counterparty?) %>
                      <%= button_to remind_agreement_path(a), method: :post,
                                    class: 'text-xs font-semibold text-red-600 hover:text-red-800 bg-transparent border-0 cursor-pointer p-0 underline' do %>
                        Remind
                      <% end %>
                    <% else %>
                      <%= link_to 'View →', agreement_path(a),
                                  class: 'text-xs font-medium text-blue-600 hover:text-blue-800' %>
                    <% end %>
                  </div>
                </div>
              <% end %>

              <% if (grouped[col[:key]] || []).empty? %>
                <p class="text-xs text-gray-400 text-center py-4">No agreements</p>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>

  <% else %>
    <div class="rounded-xl border-2 border-dashed border-gray-200 py-16 text-center">
      <svg class="w-12 h-12 text-gray-200 mx-auto mb-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25ZM6.75 12h.008v.008H6.75V12Zm0 3h.008v.008H6.75V15Zm0 3h.008v.008H6.75V18Z"/>
      </svg>
      <p class="text-gray-500 font-medium mb-1">No agreements yet</p>
      <p class="text-sm text-gray-400 mb-4">Create your first agreement to get started.</p>
      <%= link_to 'Create Agreement →', new_agreement_path,
                  class: 'inline-flex items-center px-4 py-2 rounded-lg text-sm font-semibold text-white',
                  style: 'background-color:#45AC34;' %>
    </div>
  <% end %>

</div>

<%# ── View toggle JS (persists preference in localStorage) ─────────────────── %>
<script nonce="<%= content_security_policy_nonce %>">
(function () {
  var PREF_KEY = 'igsign_agreements_view';

  function igSetView(view) {
    localStorage.setItem(PREF_KEY, view);
    applyView(view);
  }

  function applyView(view) {
    var tableEl    = document.getElementById('ig-view-table');
    var pipelineEl = document.getElementById('ig-view-pipeline');
    var btnTable   = document.getElementById('ig-btn-table');
    var btnPipeline = document.getElementById('ig-btn-pipeline');
    if (!tableEl || !pipelineEl) return;

    if (view === 'pipeline') {
      tableEl.classList.add('hidden');
      pipelineEl.classList.remove('hidden');
      if (btnPipeline) { btnPipeline.classList.add('bg-gray-200', 'text-gray-800'); }
      if (btnTable)    { btnTable.classList.remove('bg-gray-200', 'text-gray-800'); }
    } else {
      pipelineEl.classList.add('hidden');
      tableEl.classList.remove('hidden');
      if (btnTable)    { btnTable.classList.add('bg-gray-200', 'text-gray-800'); }
      if (btnPipeline) { btnPipeline.classList.remove('bg-gray-200', 'text-gray-800'); }
    }
  }

  // Expose globally so onclick handlers can call it
  window.igSetView = igSetView;

  // Apply saved preference on page load
  var saved = localStorage.getItem(PREF_KEY) || 'table';
  applyView(saved);
})();
</script>
