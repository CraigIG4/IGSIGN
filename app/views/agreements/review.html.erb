<% content_for :title, 'Review & Send' %>

<div class="max-w-2xl mx-auto px-4 py-8">

  <%# Step indicator %>
  <div class="flex items-center mb-8">
    <% [['1', 'Agreement Details'], ['2', 'Upload Document'], ['3', 'Review & Send']].each_with_index do |(n, label), i| %>
      <div class="flex items-center gap-2">
        <div class="w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold shrink-0
             <%= @step.to_i >= n.to_i ? 'text-white' : 'text-gray-400 border-2 border-gray-200 bg-white' %>"
             style="<%= @step.to_i >= n.to_i ? 'background-color:#1a2332;' : '' %>">
          <%= n %>
        </div>
        <span class="text-sm whitespace-nowrap
             <%= @step.to_i == n.to_i ? 'font-semibold text-gray-900' : 'text-gray-400' %>">
          <%= label %>
        </span>
      </div>
      <% if i < 2 %><div class="flex-1 h-px bg-gray-200 mx-3 min-w-[24px]"></div><% end %>
    <% end %>
  </div>

  <h1 class="text-xl font-bold text-gray-900 mb-1">Review &amp; Send</h1>
  <p class="text-sm text-gray-500 mb-6">Review the signing package before sending for internal approval.</p>

  <%# ── Card 1: Agreement Summary ─────────────────────────────────────────── %>
  <div class="rounded-xl border border-gray-200 bg-white mb-4 overflow-hidden">
    <div class="px-5 py-3 border-b border-gray-100 flex items-center gap-2" style="background-color:#f8fafc;">
      <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path d="M9 12h6m-6 4h6m2 5H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5.586a1 1 0 0 1 .707.293l5.414 5.414a1 1 0 0 1 .293.707V19a2 2 0 0 1-2 2z"/>
      </svg>
      <span class="text-sm font-semibold text-gray-700">Agreement Summary</span>
    </div>
    <div class="px-5 py-4 grid grid-cols-2 gap-x-6 gap-y-3 text-sm">
      <div>
        <p class="text-xs text-gray-400 uppercase tracking-wide mb-0.5">Type</p>
        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold text-white"
              style="background-color:#1a2332;">
          <%= @agreement.agreement_type_label %>
        </span>
      </div>
      <div>
        <p class="text-xs text-gray-400 uppercase tracking-wide mb-0.5">IG Entity</p>
        <p class="font-medium text-gray-900"><%= @agreement.entity_name %></p>
      </div>
      <div>
        <p class="text-xs text-gray-400 uppercase tracking-wide mb-0.5">Counterparty</p>
        <p class="font-medium text-gray-900"><%= @agreement.contracting_party.presence || '—' %></p>
        <% if @agreement.counterparty_email.present? %>
          <p class="text-xs text-gray-400"><%= @agreement.counterparty_email %></p>
        <% end %>
      </div>
      <div>
        <p class="text-xs text-gray-400 uppercase tracking-wide mb-0.5">Requestor</p>
        <p class="font-medium text-gray-900"><%= @agreement.requestor_name %></p>
      </div>
      <% if @agreement.mandate_description.present? %>
        <div class="col-span-2">
          <p class="text-xs text-gray-400 uppercase tracking-wide mb-0.5">Mandate</p>
          <p class="text-gray-700"><%= @agreement.mandate_description %></p>
        </div>
      <% end %>
    </div>
  </div>

  <%# ── Detected Counterparty Banner ──────────────────────────────────────── %>
  <% if @show_cp_detect %>
    <div id="cp_detect_card" class="rounded-xl border mb-4 overflow-hidden" style="border-color:#bfdbfe;background:#eff6ff;">
      <div class="px-5 py-3 border-b flex items-center justify-between gap-2" style="border-color:#bfdbfe;background:#dbeafe;">
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="color:#2563eb;">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z"/>
          </svg>
          <span class="text-sm font-semibold text-blue-800">Counterparty detected from document</span>
        </div>
        <button type="button" onclick="document.getElementById('cp_detect_card').style.display='none';"
                class="text-blue-400 hover:text-blue-600 text-lg leading-none font-light" title="Dismiss">&times;</button>
      </div>
      <div class="px-5 py-4">
        <p class="text-xs text-blue-600 mb-3">AI identified the counterparty from the uploaded document. Review and confirm before sending — details will be saved to your counterparty directory.</p>
        <%= form_with url: confirm_counterparty_agreement_path(@agreement), method: :patch, data: { turbo: false } do |f| %>
          <div class="grid grid-cols-2 gap-3 mb-3">
            <div>
              <label class="block text-xs font-semibold text-slate-600 mb-1">Company Name <span class="text-red-500">*</span></label>
              <%= text_field_tag :contracting_party, @detected_cp_name,
                    required: true, placeholder: 'Legal entity name',
                    style: 'width:100%;border-radius:8px;border:1px solid #93c5fd;padding:8px 10px;font-size:13px;background:white;box-sizing:border-box;' %>
            </div>
            <div>
              <label class="block text-xs font-semibold text-slate-600 mb-1">Contact Email</label>
              <%= email_field_tag :counterparty_email, @detected_cp_email,
                    placeholder: 'signatory@company.com',
                    style: 'width:100%;border-radius:8px;border:1px solid #93c5fd;padding:8px 10px;font-size:13px;background:white;box-sizing:border-box;' %>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <%= f.submit 'Confirm & Save to Directory',
                  style: 'padding:8px 18px;border-radius:8px;font-size:13px;font-weight:600;color:white;background:#162B3C;border:none;cursor:pointer;' %>
            <button type="button"
                    onclick="document.getElementById('cp_detect_card').style.display='none';"
                    style="padding:8px 14px;border-radius:8px;font-size:13px;font-weight:500;color:#6b7280;background:white;border:1px solid #d1d5db;cursor:pointer;">
              Dismiss
            </button>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# ── Card 2: Signing Package ────────────────────────────────────────────── %>
  <div class="rounded-xl border border-gray-200 bg-white mb-4 overflow-hidden">
    <div class="px-5 py-3 border-b border-gray-100 flex items-center justify-between gap-2" style="background-color:#f8fafc;">
      <div class="flex items-center gap-2">
        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M19 11H5m14 0a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-6a2 2 0 0 1 2-2m14 0V9a2 2 0 0 0-2-2M5 11V9a2 2 0 0 1 2-2m0 0V5a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v2M7 7h10"/>
        </svg>
        <span class="text-sm font-semibold text-gray-700">Signing Package — Shared with counterparty</span>
      </div>
      <% if @agreement.draft? && @agreement.template %>
        <%= link_to position_agreement_path(@agreement),
              class: 'text-xs text-gray-400 hover:text-gray-600' do %>
          Adjust field placements →
        <% end %>
      <% end %>
    </div>
    <div class="px-5 py-4 space-y-3">
      <%# Document 1: auto-generated CAF (internal only — shown for sender context) %>
      <div class="flex items-start gap-3 p-3 rounded-lg bg-amber-50 border border-amber-200">
        <span class="text-lg leading-none mt-0.5">📋</span>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-semibold text-gray-900"><%= @agreement.caf_label %></p>
          <p class="text-xs text-gray-500 mt-0.5">Auto-generated from agreement details</p>
        </div>
        <span class="shrink-0 inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-800">
          Internal only
        </span>
      </div>

      <%# Uploaded agreement documents — one card per file %>
      <% if @template_docs.any? %>
        <% @template_docs.each do |att| %>
          <div class="flex items-start gap-3 p-3 rounded-lg bg-gray-50 border border-gray-200">
            <span class="text-lg leading-none mt-0.5">📄</span>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-semibold text-gray-900 truncate"><%= att.blob.filename %></p>
              <p class="text-xs text-gray-500 mt-0.5">Sent to counterparty after internal approval</p>
            </div>
            <span class="shrink-0 inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
              Shared with counterparty
            </span>
          </div>
        <% end %>
      <% else %>
        <div class="flex items-center gap-2 p-3 rounded-lg bg-yellow-50 border border-yellow-200 text-sm text-yellow-800">
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M12 9v4m0 4h.01M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
          </svg>
          No documents uploaded yet.
          <%= link_to 'Upload one →', upload_agreement_path(@agreement), class: 'font-medium underline' %>
        </div>
      <% end %>
    </div>
  </div>

  <%# ── Card 3: Signing Journey ───────────────────────────────────────────── %>
  <div class="rounded-xl border border-gray-200 bg-white mb-4 overflow-hidden">
    <div class="px-5 py-3 border-b border-gray-100 flex items-center justify-between gap-2" style="background-color:#f8fafc;">
      <div class="flex items-center gap-2">
        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
          <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
        </svg>
        <span class="text-sm font-semibold text-gray-700">Signing journey</span>
      </div>
      <% if current_user.role == User::ADMIN_ROLE && @agreement.draft? %>
        <button type="button" id="sj_edit_btn"
                onclick="document.getElementById('sj_editor').style.display='block';document.getElementById('sj_journey').style.display='none';this.style.display='none';"
                style="font-size:12px;font-weight:500;color:#162B3C;background:none;border:1px solid #d1d5db;border-radius:6px;padding:4px 10px;cursor:pointer;">
          Edit chain
        </button>
      <% end %>
    </div>
    <div id="sj_journey" class="px-5 py-5 overflow-x-auto">
      <%= render 'signing_journey',
                 agreement:              @agreement,
                 signatories:            @signatories,
                 mode:                   :preview,
                 counterparty_signatory: @counterparty_signatory %>
    </div>

    <%# ── Signing Chain Editor (admin, draft only) ──── %>
    <% if current_user.role == User::ADMIN_ROLE && @agreement.draft? %>
      <div id="sj_editor" style="display:none;padding:16px 20px;border-top:1px solid #e5e7eb;">
        <p style="font-size:12px;color:#6b7280;margin-bottom:12px;">
          Modify the internal signing chain. The counterparty is always the final signer and cannot be removed.
          Changes apply to this agreement only and are logged for audit.
        </p>

        <%# Available signatories JSON for the JS picker %>
        <script id="avail_sigs_data" type="application/json"><%= raw @available_signatories.to_json %></script>

        <div id="sj_chain_list" style="display:flex;flex-direction:column;gap:8px;margin-bottom:12px;"></div>

        <div style="display:flex;gap:8px;margin-bottom:14px;align-items:center;">
          <select id="sj_add_select"
                  style="flex:1;border-radius:8px;border:1px solid #d1d5db;padding:8px 10px;font-size:13px;background:white;">
            <option value="">— Add a signatory —</option>
          </select>
          <button type="button" id="sj_add_btn"
                  onclick="sjAddSelected();"
                  style="padding:8px 14px;border-radius:8px;font-size:13px;font-weight:600;color:white;background:#162B3C;border:none;cursor:pointer;">
            Add
          </button>
        </div>

        <%= form_with url: update_signing_chain_agreement_path(@agreement), method: :patch, data: { turbo: false }, html: { id: 'sj_edit_form' } do |f| %>
          <%= hidden_field_tag :signatories_json, '', id: 'sj_json_field' %>
          <div style="display:flex;gap:8px;">
            <%= f.submit 'Save chain',
                  style: 'padding:8px 18px;border-radius:8px;font-size:13px;font-weight:600;color:white;background:#45AC34;border:none;cursor:pointer;',
                  onclick: 'return sjPrepareSubmit()' %>
            <button type="button"
                    onclick="document.getElementById('sj_editor').style.display='none';document.getElementById('sj_journey').style.display='block';document.getElementById('sj_edit_btn').style.display='inline-flex';"
                    style="padding:8px 14px;border-radius:8px;font-size:13px;font-weight:500;color:#6b7280;background:white;border:1px solid #d1d5db;cursor:pointer;">
              Cancel
            </button>
          </div>
        <% end %>
      </div>

      <script nonce="<%= content_security_policy_nonce %>">
      (function() {
        var AVAIL = JSON.parse(document.getElementById('avail_sigs_data').textContent || '[]');
        var CHAIN = <%= raw (@signatories.reject { |s| s['chain_position'] == 'counterparty' }).to_json %>;

        var chainList = document.getElementById('sj_chain_list');
        var addSelect = document.getElementById('sj_add_select');

        // Populate add dropdown
        AVAIL.forEach(function(s) {
          var opt = document.createElement('option');
          opt.value = s.id;
          opt.textContent = s.name + ' — ' + s.role_title + (s.entities ? ' (' + s.entities + ')' : '');
          addSelect.appendChild(opt);
        });

        function renderChain() {
          chainList.innerHTML = '';
          if (!CHAIN.length) {
            chainList.innerHTML = '<p style="font-size:12px;color:#9ca3af;padding:4px 0;">No internal signatories — add at least one.</p>';
            return;
          }
          CHAIN.forEach(function(sig, idx) {
            var row = document.createElement('div');
            row.style.cssText = 'display:flex;align-items:center;gap:10px;padding:8px 12px;border-radius:8px;background:#f9fafb;border:1px solid #e5e7eb;';
            row.innerHTML =
              '<span style="width:22px;height:22px;border-radius:50%;background:#162B3C;color:#fff;font-size:11px;font-weight:700;display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;">' + (idx + 1) + '</span>' +
              '<div style="flex:1;min-width:0;">' +
                '<p style="font-size:13px;font-weight:600;color:#111827;margin:0;">' + escH(sig.name || sig.role || '') + '</p>' +
                '<p style="font-size:11px;color:#6b7280;margin:0;">' + escH(sig.email || '') + ' &bull; ' + escH(sig.role || sig.chain_position || '') + '</p>' +
              '</div>' +
              '<button type="button" data-idx="' + idx + '" style="color:#ef4444;background:none;border:none;cursor:pointer;font-size:16px;line-height:1;" title="Remove">&times;</button>';
            row.querySelector('button').addEventListener('click', function() {
              var i = parseInt(this.dataset.idx, 10);
              CHAIN.splice(i, 1);
              renderChain();
            });
            chainList.appendChild(row);
          });
        }

        window.sjAddSelected = function() {
          var sel = addSelect;
          var id = parseInt(sel.value, 10);
          if (!id) return;
          var sig = AVAIL.find(function(s) { return s.id === id; });
          if (!sig) return;
          if (CHAIN.find(function(s) { return s.email === sig.email; })) {
            alert(sig.name + ' is already in the chain.');
            return;
          }
          CHAIN.push({ name: sig.name, email: sig.email, role: sig.role_title, chain_position: 'approver_only', placeholder: false });
          sel.value = '';
          renderChain();
        };

        window.sjPrepareSubmit = function() {
          if (!CHAIN.length) { alert('Add at least one internal signatory before saving.'); return false; }
          document.getElementById('sj_json_field').value = JSON.stringify(CHAIN);
          return true;
        };

        function escH(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

        renderChain();
      })();
      </script>
    <% end %>

    <%# Authority note (shown below journey when there's a memorised signatory) %>
    <% if @counterparty_signatory %>
      <div class="px-5 pb-4">
        <% if @counterparty_signatory.authority_on_file? %>
          <p class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-green-50 text-green-700 border border-green-200">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
            Authority on file for <%= @counterparty_signatory.name.split.first %>: <%= @counterparty_signatory.authority_basis.truncate(60) %>
          </p>
        <% elsif @agreement.agreement_type.in?(%w[msa sla vendor employment]) %>
          <p class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-amber-50 text-amber-700 border border-amber-200">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/></svg>
            No authority basis on file for <%= @counterparty_signatory.name.split.first %> —
            verify signing authority for <%= @agreement.contracting_party.presence || 'this company' %>.
          </p>
        <% end %>
      </div>
    <% end %>
  </div>

  <%# ── Pre-fill banner ──────────────────────────────────────────────────────── %>
  <% if @parsed['error'].present? %>
    <div class="rounded-xl border mb-4 px-4 py-3 flex items-start gap-3 text-sm" style="background:#fef2f2;border-color:#fecaca;">
      <svg class="w-4 h-4 mt-0.5 shrink-0 text-red-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v4m0 4h.01M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/></svg>
      <div class="flex-1">
        <p class="font-semibold text-red-700">Automatic extraction failed</p>
        <p class="text-red-600 text-xs mt-0.5">Fields were not pre-filled. <strong>Complete contract data manually</strong> before sending.</p>
      </div>
      <%= link_to contract_data_legal_ops_workflow_path(@agreement),
            class: 'shrink-0 text-xs font-semibold text-red-700 underline' do %>Complete now →<% end %>
    </div>
  <% elsif @parsed.blank? && @template_docs.any? %>
    <%# Parsing job is in flight — poll every 5 seconds until it completes %>
    <script nonce="<%= content_security_policy_nonce %>">setTimeout(function(){ location.reload(); }, 5000);</script>
    <div class="rounded-xl border mb-4 px-4 py-3 flex items-center gap-3 text-sm" style="background:#fffbeb;border-color:#fde68a;">
      <svg class="w-4 h-4 shrink-0 animate-spin" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="color:#d97706;"><path stroke-linecap="round" stroke-linejoin="round" d="M4 12a8 8 0 0 1 8-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 0 1 4 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"/></svg>
      <p class="text-amber-700">Analysing your document — fields will be auto-filled shortly. This page will refresh automatically.</p>
    </div>
  <% elsif @prefill_present %>
    <div class="rounded-xl border mb-4 px-4 py-3 flex items-center justify-between gap-3 text-sm" style="background:#f0fdf4;border-color:#bbf7d0;">
      <div class="flex items-center gap-2">
        <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="color:#00C853;"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z"/></svg>
        <p class="text-green-700 font-medium">Fields pre-filled from contract — please review before sending.</p>
      </div>
      <%= link_to contract_data_legal_ops_workflow_path(@agreement),
            class: 'shrink-0 text-xs font-semibold text-green-700 underline' do %>Review & edit fields →<% end %>
    </div>
  <% end %>

  <%# ── Amends / relates-to suggestion ───────────────────────────────────────── %>
  <% if @amends_suggestion&.any? %>
    <div class="rounded-xl border mb-4 px-4 py-3 text-sm" style="background:#eff6ff;border-color:#bfdbfe;">
      <p class="font-semibold text-blue-700 mb-1">This document references related agreements</p>
      <p class="text-blue-600 text-xs mb-2">
        Extraction suggests this document relates to:
        <strong><%= Array(@amends_suggestion).join(', ') %></strong>
      </p>
      <%= link_to contract_data_legal_ops_workflow_path(@agreement),
            class: 'text-xs font-semibold text-blue-700 underline' do %>Link related agreements in Legal Ops →<% end %>
    </div>
  <% end %>

  <%# ── Card 4: Smart Summary (Sprint 0 schema keys) ─────────────────────────── %>
  <% if @parsed.present? && @parsed['error'].blank? %>
    <div class="rounded-xl border border-gray-200 bg-white mb-4 overflow-hidden">
      <div class="px-5 py-3 border-b border-gray-100 flex items-center justify-between" style="background-color:#f8fafc;">
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="color:#00C853;">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z"/>
          </svg>
          <span class="text-sm font-semibold text-gray-700">Smart Summary</span>
        </div>
        <span class="inline-flex items-center gap-1 text-xs text-gray-400">AI-generated · verify before relying on</span>
      </div>
      <div class="px-5 py-4 space-y-3 text-sm">

        <%# High-level summary %>
        <% summary = @agreement.high_level_summary.presence || @parsed['high_level_summary'] %>
        <% if summary.present? %>
          <p class="text-gray-700 leading-relaxed italic"><%= summary %></p>
        <% end %>

        <%# Key data grid — driven by CafFieldSchema dashboard fields %>
        <div class="grid grid-cols-2 gap-x-6 gap-y-2 text-sm pt-1">
          <% {
            'Contract Type'   => @agreement.agreement_type_label,
            'Value'           => @agreement.agreement_value.presence || @parsed['sow_value'],
            'Period'          => @agreement.agreement_term.presence || @parsed['period'],
            'Governing Law'   => @agreement.governing_law.presence || @parsed['governing_law'],
            'Effective Date'  => @agreement.effective_date&.strftime('%d %b %Y') || @parsed['effective_date'],
            'Expiry Date'     => @agreement.expiry_date&.strftime('%d %b %Y') || @parsed['expiry_date'],
            'Auto-renewal'    => (@agreement.auto_renewal.nil? ? @parsed['auto_renewal'] : @agreement.auto_renewal)&.then { |v| v ? 'Yes ⚠' : 'No' },
            'Payment Terms'   => (@agreement.payment_terms_days.present? ? "#{@agreement.payment_terms_days} days" : @parsed['payment_terms_days']&.then { |d| "#{d} days" })
          }.each do |label, value| %>
            <% next unless value.present? %>
            <div>
              <p class="text-xs text-gray-400 uppercase tracking-wide mb-0.5"><%= label %></p>
              <p class="font-medium <%= value.to_s.include?('⚠') ? 'text-amber-600' : 'text-gray-900' %>"><%= value %></p>
            </div>
          <% end %>
        </div>

        <%# Material risks %>
        <% risks_raw = @agreement.key_risks.presence || @parsed['material_risks'] %>
        <% risks = Array(risks_raw.is_a?(Array) ? risks_raw : risks_raw&.split(';')).map(&:strip).reject(&:blank?) %>
        <% if risks.any? %>
          <div class="pt-1">
            <p class="text-xs text-red-500 uppercase tracking-wide mb-2 font-semibold">⚠ Material Risks</p>
            <div class="space-y-1">
              <% risks.each do |risk| %>
                <div style="background:#fef2f2;border:1px solid #fecaca;border-radius:6px;padding:6px 10px;">
                  <p class="text-xs text-red-700 leading-relaxed"><%= risk %></p>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>

        <%# Liability flags %>
        <% if @agreement.liability_cap == 'Not Included' || @parsed['liability_aggregate_cap'] == 'Not Included' %>
          <div style="background:#fef2f2;border:1px solid #fecaca;border-radius:6px;padding:6px 10px;">
            <p class="text-xs text-red-700 font-semibold">⚠ No aggregate liability cap — unlimited exposure</p>
          </div>
        <% end %>

      </div>
    </div>
  <% end %>

  <%# Submission note %>
  <% first_signer = @signatories.first %>
  <% if first_signer %>
    <p class="text-xs text-gray-500 text-center mb-4">
      By submitting, this agreement will be sent to
      <strong><%= first_signer['name'].presence || first_signer['role'] %></strong>
      for review.
    </p>
  <% end %>

  <%# ECT Act notice %>
  <p class="text-xs text-gray-400 text-center mb-6">
    This agreement will be executed in accordance with the Electronic Communications and Transactions Act 25 of 2002 (SES-grade). All signatures constitute valid electronic signatures.
  </p>

  <%# Actions %>
  <div class="flex items-center justify-between pt-4 border-t border-gray-200">
    <%# NDA agreements skip the upload + field-placement steps, so the back link
        would point to a page the user was never on. Show it only for upload path. %>
    <% unless @agreement.agreement_type == 'nda' %>
      <div class="flex flex-col gap-2">
        <%= link_to position_agreement_path(@agreement), class: 'text-sm text-gray-500 hover:text-gray-700' do %>
          ← Back to Field Placement
        <% end %>
        <% if @agreement.draft? %>
          <%= link_to replace_document_agreement_path(@agreement),
                      method: :patch,
                      data: { turbo: false, confirm: 'Remove the current document and upload a replacement? Field placements will be lost.' },
                      class: 'text-xs text-red-400 hover:text-red-600' do %>
            Replace document…
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div></div>
    <% end %>

    <div class="flex items-center gap-3">
      <%= link_to caf_preview_agreement_path(@agreement), target: '_blank',
                  class: 'px-4 py-2.5 rounded-lg text-sm font-semibold border border-gray-300 text-gray-600 hover:bg-gray-50 transition-colors' do %>
        <span class="flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M7 21h10a2 2 0 0 0 2-2V9.414a1 1 0 0 0-.293-.707l-5.414-5.414A1 1 0 0 0 13 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2z"/>
          </svg>
          Preview CAF
        </span>
      <% end %>
      <% unfilled_roles = (@agreement.signatories || []).select { |s| s['placeholder'] }.map { |s| s['role'].presence || 'Unknown role' } %>
      <% if unfilled_roles.any? %>
        <div class="rounded-lg border border-amber-200 bg-amber-50 px-4 py-3 text-xs text-amber-800 max-w-sm">
          <p class="font-semibold mb-1">Assign signatories before sending:</p>
          <ul class="list-disc list-inside space-y-0.5">
            <% unfilled_roles.each do |role| %>
              <li><%= role %></li>
            <% end %>
          </ul>
        </div>
      <% end %>
      <%= form_with url: send_agreement_agreement_path(@agreement), method: :post, data: { turbo: false } do |f| %>
        <%= f.submit 'Send for Internal Approval →',
                     disabled: unfilled_roles.any?,
                     class: "px-6 py-2.5 rounded-lg text-sm font-semibold text-white transition-colors #{unfilled_roles.any? ? 'opacity-40 cursor-not-allowed' : 'cursor-pointer hover:opacity-90'}",
                     style: 'background-color:#45AC34;' %>
      <% end %>
    </div>
  </div>

</div>

<% if IgsignLlmClient.configured? %>
  <%= render 'gcip/wizard_panel', workflow: @agreement %>
<% end %>
