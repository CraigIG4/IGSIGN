<%#
  Shared form for admin template metadata edit.
  Locals: template (Template), metadata (IgsignTemplateMetadata)
  Handles both unsaved (new_record?) and existing metadata.
%>
<% legal_users = current_account.users.order(:first_name, :last_name) %>

<%= form_with model: metadata,
              url: metadata.new_record? ? legal_ops_templates_path : legal_ops_template_path(template),
              method: metadata.new_record? ? :post : :patch,
              scope: :igsign_template_metadata,
              local: true do |f| %>

  <% if metadata.errors.any? %>
    <div class="alert alert-error mb-4">
      <ul style="margin:0;padding-left:16px;">
        <% metadata.errors.full_messages.each do |msg| %>
          <li style="font-size:13px;"><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# Hidden template_id for create path %>
  <%= hidden_field_tag :template_id, template.id if metadata.new_record? %>

  <div class="card mb-6" style="padding:24px;">
    <h3 class="igsign-section-head" style="font-size:14px;margin-bottom:16px;">Template details</h3>

    <%# Read-only template name %>
    <div style="margin-bottom:16px;">
      <p style="font-size:13px;font-weight:600;margin-bottom:4px;">IGSIGN template</p>
      <div style="display:flex;align-items:center;gap:12px;padding:10px 14px;background:#f8fafb;border:1px solid #e2e8f0;border-radius:8px;">
        <span style="font-size:14px;font-weight:600;color:#162B3C;flex:1;"><%= template.name %></span>
        <%= link_to 'Edit fields →', edit_template_path(template),
              style: 'font-size:12px;color:#45AC34;text-decoration:none;white-space:nowrap;font-weight:600;',
              data: { turbo: false } %>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <%= f.label :kind, 'Agreement kind', style: 'display:block;font-size:13px;font-weight:600;margin-bottom:4px;' %>
        <%= f.select :kind,
              IgsignTemplateMetadata::KINDS.map { |k| [IgsignTemplateMetadata::KIND_LABELS[k], k] },
              {},
              class: 'select select-bordered w-full',
              style: 'font-size:13px;' %>
      </div>

      <div>
        <%= f.label :owner_id, 'Owner (Legal team member)', style: 'display:block;font-size:13px;font-weight:600;margin-bottom:4px;' %>
        <%= f.select :owner_id,
              legal_users.map { |u| [u.full_name, u.id] },
              { include_blank: '— Unassigned —' },
              class: 'select select-bordered w-full',
              style: 'font-size:13px;' %>
      </div>

      <div>
        <%= f.label :status, 'Status', style: 'display:block;font-size:13px;font-weight:600;margin-bottom:4px;' %>
        <%= f.select :status,
              IgsignTemplateMetadata::STATUSES.map { |s| [IgsignTemplateMetadata::STATUS_LABELS[s], s] },
              {},
              class: 'select select-bordered w-full',
              style: 'font-size:13px;' %>
        <p style="font-size:11px;color:#7B787F;margin-top:4px;">Only <strong>Active</strong> templates appear in the sender library.</p>
      </div>

      <% unless metadata.new_record? %>
        <div>
          <p style="font-size:13px;font-weight:600;margin-bottom:4px;">Version</p>
          <div style="padding:9px 12px;background:#f8fafb;border:1px solid #e2e8f0;border-radius:8px;font-size:14px;font-weight:700;color:#162B3C;">
            v<%= metadata.version %>
            <span style="font-size:11px;color:#7B787F;font-weight:400;margin-left:6px;">auto-increments on save when Active</span>
          </div>
        </div>
      <% end %>
    </div>

    <%# Entity scope — only relevant for NDA templates (kind='nda').
        Stored as a JSONB array, edited here as a comma-separated text field.
        Admin JS converts on submit; controller permits the string and converts
        it back to an array before save via strong params. %>
    <div style="margin-top:16px;" id="entity_scope_field">
      <%= f.label :entity_scope_csv, 'Entity scope (NDA only)', style: 'display:block;font-size:13px;font-weight:600;margin-bottom:4px;' %>
      <input type="text"
             id="entity_scope_csv"
             name="igsign_template_metadata[entity_scope_csv]"
             value="<%= Array(metadata.entity_scope).join(', ') %>"
             placeholder="e.g. iti, comit  (leave blank for all entities)"
             style="width:100%;border-radius:8px;border:1px solid #d1d5db;padding:9px 12px;font-size:13px;box-sizing:border-box;">
      <p style="font-size:11px;color:#7B787F;margin-top:4px;">
        Comma-separated entity keys (e.g. <code>iti</code>, <code>comit</code>).
        Leave blank for a generic template that applies to all entities.
        Valid keys: <code><%= IgEntity.active.pluck(:key).join(', ') %></code>
      </p>
    </div>

    <div style="margin-top:16px;">
      <%= f.label :notes, 'Internal notes (Legal team only)', style: 'display:block;font-size:13px;font-weight:600;margin-bottom:4px;' %>
      <%= f.text_area :notes,
            rows: 3,
            placeholder: 'e.g. Approved by board 2025-01. Supersedes v3.',
            class: 'textarea textarea-bordered w-full',
            style: 'font-size:13px;' %>
    </div>
  </div>

  <div style="display:flex;gap:12px;align-items:center;">
    <%= f.submit metadata.new_record? ? 'Save metadata' : 'Update metadata',
          class: 'btn btn-primary',
          style: 'min-width:160px;' %>
    <%= link_to 'Cancel', legal_ops_templates_path,
          style: 'font-size:14px;color:#7B787F;text-decoration:none;' %>
  </div>
<% end %>
