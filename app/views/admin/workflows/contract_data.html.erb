<%# IGSIGN — Contract Data review/edit form. Driven by CafFieldSchema. %>
<% content_for :title, "Contract Data — #{@caf.contracting_party.presence || 'CAF'}" %>

<div style="max-width:860px; margin:0 auto; padding:24px 16px;">

  <%# Back link %>
  <%= link_to legal_ops_workflow_path(@caf),
        style: "color:#7B787F;text-decoration:none;font-size:13px;display:inline-flex;align-items:center;gap:4px;margin-bottom:20px;" do %>
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
    Back to workflow
  <% end %>

  <div style="margin-bottom:24px;">
    <p style="font-size:11px;color:#7B787F;letter-spacing:3px;text-transform:uppercase;margin-bottom:4px;">IGSIGN — Contract Data</p>
    <h1 style="font-size:24px;font-weight:800;color:#0B1722;margin:0;"><%= @caf.contracting_party.presence || 'Untitled Agreement' %></h1>
    <div style="width:32px;height:3px;background:#00C853;border-radius:2px;margin-top:8px;"></div>
  </div>

  <%# Parse status banner %>
  <% if @data['error'].present? %>
    <div style="background:#FEF2F2;border:1px solid #FECACA;border-radius:10px;padding:16px 20px;margin-bottom:20px;color:#DC2626;">
      <strong>Automatic extraction failed:</strong> <%= @data['error'] %>.
      Please complete the fields below manually.
    </div>
  <% elsif @data.blank? %>
    <div style="background:#FFFBEB;border:1px solid #FDE68A;border-radius:10px;padding:16px 20px;margin-bottom:20px;color:#92400E;">
      Extraction is pending or has not run. Fields shown are empty.
    </div>
  <% elsif CafFieldSchema.dashboard_fields.all? { |f| @data[f[:key].to_s].present? || @caf.public_send(f[:caf_column]).present? rescue false } %>
    <div style="background:#ECFDF5;border:1px solid #A7F3D0;border-radius:10px;padding:16px 20px;margin-bottom:20px;color:#065F46;">
      Contract data complete.
    </div>
  <% end %>

  <%# Re-parse button %>
  <div style="display:flex;justify-content:flex-end;margin-bottom:20px;">
    <%= button_to reparse_legal_ops_workflow_path(@caf), method: :post,
          style: "background:#F3F4F6;color:#374151;border:none;border-radius:8px;padding:8px 16px;font-size:13px;cursor:pointer;",
          data: { confirm: "Re-parsing will overwrite AI-extracted fields but preserve manually entered fields. Continue?" },
          form: { data: { turbo: false } } do %>
      Re-parse contract
    <% end %>
  </div>

  <%= form_with url: contract_data_legal_ops_workflow_path(@caf), method: :patch,
        data: { turbo: false },
        style: "display:block;" do |f| %>

    <% @fields.each do |field| %>
      <% key = field[:key].to_s %>
      <% current_value = @data[key] %>
      <% prov = @provenance[key] %>

      <% clause_ref = @data.dig('clause_refs', key) %>
      <div style="background:#fff;border:1px solid #E5E7EB;border-radius:10px;padding:20px;margin-bottom:16px;">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;flex-wrap:wrap;gap:6px;">
          <label for="field_<%= key %>" style="font-size:13px;font-weight:700;color:#0B1722;">
            <%= field[:label] %>
          </label>
          <div style="display:flex;align-items:center;gap:8px;">
            <% if clause_ref.present? %>
              <span title="Source clause from contract" style="background:#EFF6FF;color:#1D4ED8;font-size:11px;font-weight:600;padding:2px 8px;border-radius:99px;cursor:default;">
                📄 <%= clause_ref %>
              </span>
            <% end %>
            <% if prov == 'ai' %>
              <span style="background:#DCFCE7;color:#166534;font-size:11px;font-weight:600;padding:2px 8px;border-radius:99px;">AI</span>
            <% elsif prov == 'manual' %>
              <span style="background:#F3F4F6;color:#6B7280;font-size:11px;font-weight:600;padding:2px 8px;border-radius:99px;">Manual</span>
            <% end %>
          </div>
        </div>

        <% case field[:type]
           when :enum %>
          <select id="field_<%= key %>" name="<%= key %>"
            style="width:100%;border:1px solid #D1D5DB;border-radius:6px;padding:8px 10px;font-size:13px;color:#111827;">
            <option value="">— select —</option>
            <% field[:options].each do |opt| %>
              <option value="<%= opt %>" <%= 'selected' if current_value.to_s == opt %>><%= opt %></option>
            <% end %>
          </select>

        <% when :date %>
          <input id="field_<%= key %>" name="<%= key %>" type="date"
            value="<%= current_value %>"
            style="border:1px solid #D1D5DB;border-radius:6px;padding:8px 10px;font-size:13px;color:#111827;">

        <% when :boolean %>
          <div style="display:flex;gap:16px;">
            <% [['Yes', 'true'], ['No', 'false'], ['Unknown', '']].each do |label, val| %>
              <label style="display:flex;align-items:center;gap:6px;font-size:13px;color:#374151;cursor:pointer;">
                <input type="radio" name="<%= key %>" value="<%= val %>"
                  <%= 'checked' if current_value.to_s == val || (val.blank? && current_value.nil?) %>>
                <%= label %>
              </label>
            <% end %>
          </div>

        <% when :integer %>
          <input id="field_<%= key %>" name="<%= key %>" type="number"
            value="<%= current_value %>"
            style="border:1px solid #D1D5DB;border-radius:6px;padding:8px 10px;font-size:13px;color:#111827;width:160px;">

        <% when :text %>
          <textarea id="field_<%= key %>" name="<%= key %>" rows="4"
            style="width:100%;border:1px solid #D1D5DB;border-radius:6px;padding:8px 10px;font-size:13px;color:#111827;resize:vertical;"><%= current_value %></textarea>

        <% when :payment_terms %>
          <%# Structured payment terms builder — each row: direction, type, amount, frequency, notes %>
          <% pt_rows = Array(current_value).is_a?(Array) ? Array(current_value) : [] %>
          <div id="pt_builder_<%= key %>" style="display:flex;flex-direction:column;gap:8px;">

            <%# Hidden field — stores JSON array, updated by JS %>
            <input type="hidden" id="pt_json_<%= key %>" name="<%= key %>" value="<%= pt_rows.to_json.html_safe %>">

            <%# Existing rows (rendered server-side on load) %>
            <% pt_rows.each_with_index do |row, idx| %>
              <div class="pt-row" style="display:grid;grid-template-columns:140px 140px 120px 120px 1fr auto;gap:6px;align-items:center;background:#f9fafb;border:1px solid #e5e7eb;border-radius:8px;padding:8px;">
                <select class="pt-dir" style="border:1px solid #D1D5DB;border-radius:6px;padding:6px 8px;font-size:12px;">
                  <option value="cp_pays" <%= 'selected' if row['direction'] == 'cp_pays' %>>CP pays IG →</option>
                  <option value="ig_pays" <%= 'selected' if row['direction'] == 'ig_pays' %>>IG pays CP →</option>
                </select>
                <select class="pt-type" style="border:1px solid #D1D5DB;border-radius:6px;padding:6px 8px;font-size:12px;">
                  <% ['$/sale','$/hr','$/head','Fixed fee','Retainer','Milestone','Revenue share %','Other'].each do |t| %>
                    <option value="<%= t %>" <%= 'selected' if row['type'] == t %>><%= t %></option>
                  <% end %>
                </select>
                <input class="pt-amount" type="text" placeholder="Amount/Rate" value="<%= row['amount'] %>"
                  style="border:1px solid #D1D5DB;border-radius:6px;padding:6px 8px;font-size:12px;">
                <input class="pt-freq" type="text" placeholder="Frequency" value="<%= row['frequency'] %>"
                  style="border:1px solid #D1D5DB;border-radius:6px;padding:6px 8px;font-size:12px;">
                <input class="pt-notes" type="text" placeholder="Notes (optional)" value="<%= row['notes'] %>"
                  style="border:1px solid #D1D5DB;border-radius:6px;padding:6px 8px;font-size:12px;">
                <button type="button" onclick="ptRemoveRow(this, '<%= key %>')"
                  style="color:#ef4444;background:none;border:none;cursor:pointer;font-size:18px;line-height:1;padding:2px 4px;">&times;</button>
              </div>
            <% end %>

            <%# Empty state %>
            <% if pt_rows.empty? %>
              <p id="pt_empty_<%= key %>" style="font-size:12px;color:#9ca3af;font-style:italic;">No payment terms added. Use the button below to add one.</p>
            <% end %>
          </div>

          <button type="button" onclick="ptAddRow('<%= key %>')"
            style="margin-top:8px;display:inline-flex;align-items:center;gap:6px;font-size:12px;font-weight:600;color:#0B1722;background:#f3f4f6;border:1px solid #d1d5db;border-radius:6px;padding:6px 12px;cursor:pointer;">
            + Add payment term
          </button>

        <% when :array %>
          <% if field[:options].present? %>
            <%# Array with predefined options — render as checkboxes (multi-select) %>
            <% selected_values = Array(current_value).map(&:to_s) %>
            <div style="display:flex;flex-wrap:wrap;gap:8px 16px;">
              <% field[:options].each do |opt| %>
                <label style="display:flex;align-items:center;gap:6px;font-size:13px;color:#374151;cursor:pointer;">
                  <input type="checkbox" name="<%= key %>[]" value="<%= opt %>"
                    <%= 'checked' if selected_values.include?(opt.to_s) %>
                    style="width:14px;height:14px;">
                  <%= opt %>
                </label>
              <% end %>
            </div>
          <% else %>
            <%# Free-form array — one item per line textarea %>
            <textarea id="field_<%= key %>" name="<%= key %>" rows="3"
              style="width:100%;border:1px solid #D1D5DB;border-radius:6px;padding:8px 10px;font-size:13px;color:#111827;resize:vertical;"
              placeholder="One item per line"><%= Array(current_value).join("\n") %></textarea>
          <% end %>

        <% else %>
          <input id="field_<%= key %>" name="<%= key %>" type="text"
            value="<%= current_value %>"
            style="width:100%;border:1px solid #D1D5DB;border-radius:6px;padding:8px 10px;font-size:13px;color:#111827;">
        <% end %>
      </div>
    <% end %>

    <%# Validation feedback banner — shown by JS when fields are missing %>
    <div id="validation_banner" style="display:none;margin-top:16px;padding:14px 18px;background:#FEF2F2;border:1px solid #FECACA;border-radius:10px;">
      <p style="font-size:13px;font-weight:700;color:#DC2626;margin-bottom:6px;">Please review the following before saving:</p>
      <ul id="validation_list" style="font-size:13px;color:#DC2626;margin:0;padding-left:18px;line-height:1.8;"></ul>
    </div>

    <div style="margin-top:24px;display:flex;align-items:center;justify-content:space-between;">
      <p style="font-size:12px;color:#9CA3AF;margin:0;">
        Fields marked <strong>AI</strong> were extracted automatically. Review and correct before sending.
      </p>
      <button type="button" id="save_btn" onclick="handleSave(event)"
        style="background:#00C853;color:#fff;border:none;border-radius:8px;padding:12px 28px;font-size:14px;font-weight:700;cursor:pointer;min-width:160px;transition:opacity 0.15s;">
        Save contract data
      </button>
    </div>
  <% end %>

</div>

<script>
// ── Save with feedback ─────────────────────────────────────────────────────

// Key fields that should be populated before sending — not hard-blocked but warned
var RECOMMENDED_FIELDS = {
  'contract_type':      'Contract Type',
  'high_level_summary': 'High-Level Summary',
  'effective_date':     'Effective Date',
  'governing_law':      'Governing Law'
};

window.handleSave = function(e) {
  ptSyncAllBeforeSubmit();

  var warnings = [];
  Object.keys(RECOMMENDED_FIELDS).forEach(function(key) {
    var el = document.getElementById('field_' + key) ||
             document.querySelector('[name="' + key + '"]');
    if (!el) return;
    var val = (el.value || el.textContent || '').trim();
    if (!val) warnings.push(RECOMMENDED_FIELDS[key] + ' is empty');
  });

  var banner = document.getElementById('validation_banner');
  var list   = document.getElementById('validation_list');
  var btn    = document.getElementById('save_btn');
  var form   = btn.closest('form');

  if (warnings.length > 0) {
    // Show warnings but still allow save after user acknowledges
    list.innerHTML = warnings.map(function(w) { return '<li>' + w + '</li>'; }).join('');
    banner.style.display = 'block';
    banner.scrollIntoView({ behavior: 'smooth', block: 'nearest' });

    // Add a second "Save anyway" option
    if (!document.getElementById('save_anyway_btn')) {
      var saveAnyway = document.createElement('button');
      saveAnyway.id = 'save_anyway_btn';
      saveAnyway.type = 'button';
      saveAnyway.textContent = 'Save anyway →';
      saveAnyway.style.cssText = 'margin-top:10px;background:none;border:1px solid #DC2626;color:#DC2626;border-radius:6px;padding:6px 14px;font-size:12px;font-weight:600;cursor:pointer;';
      saveAnyway.onclick = function() { submitForm(form, btn); };
      banner.appendChild(saveAnyway);
    }
    return;
  }

  submitForm(form, btn);
};

function submitForm(form, btn) {
  // Show loading state
  btn.textContent = 'Saving…';
  btn.disabled = true;
  btn.style.opacity = '0.7';

  // Hide any existing validation banner
  var banner = document.getElementById('validation_banner');
  if (banner) banner.style.display = 'none';

  form.submit();
}

// ── Payment Terms Builder ──────────────────────────────────────────────────
var PT_TYPES = ['$/sale','$/hr','$/head','Fixed fee','Retainer','Milestone','Revenue share %','Other'];

function ptRowHtml(key) {
  var typeOpts = PT_TYPES.map(function(t) {
    return '<option value="' + t + '">' + t + '</option>';
  }).join('');
  return '<div class="pt-row" style="display:grid;grid-template-columns:140px 140px 120px 120px 1fr auto;gap:6px;align-items:center;background:#f9fafb;border:1px solid #e5e7eb;border-radius:8px;padding:8px;">' +
    '<select class="pt-dir" style="border:1px solid #D1D5DB;border-radius:6px;padding:6px 8px;font-size:12px;">' +
      '<option value="cp_pays">CP pays IG &rarr;</option>' +
      '<option value="ig_pays">IG pays CP &rarr;</option>' +
    '</select>' +
    '<select class="pt-type" style="border:1px solid #D1D5DB;border-radius:6px;padding:6px 8px;font-size:12px;">' + typeOpts + '</select>' +
    '<input class="pt-amount" type="text" placeholder="Amount/Rate" style="border:1px solid #D1D5DB;border-radius:6px;padding:6px 8px;font-size:12px;">' +
    '<input class="pt-freq"   type="text" placeholder="Frequency"   style="border:1px solid #D1D5DB;border-radius:6px;padding:6px 8px;font-size:12px;">' +
    '<input class="pt-notes"  type="text" placeholder="Notes (optional)" style="border:1px solid #D1D5DB;border-radius:6px;padding:6px 8px;font-size:12px;">' +
    '<button type="button" onclick="ptRemoveRow(this,\'' + key + '\')" style="color:#ef4444;background:none;border:none;cursor:pointer;font-size:18px;line-height:1;padding:2px 4px;">&times;</button>' +
  '</div>';
}

window.ptAddRow = function(key) {
  var builder = document.getElementById('pt_builder_' + key);
  var empty   = document.getElementById('pt_empty_' + key);
  if (empty) empty.remove();
  var div = document.createElement('div');
  div.innerHTML = ptRowHtml(key);
  builder.insertBefore(div.firstChild, builder.lastElementChild);
  // lastElementChild is the hidden input — keep it at the bottom
  ptSync(key);
};

window.ptRemoveRow = function(btn, key) {
  btn.closest('.pt-row').remove();
  ptSync(key);
};

function ptSync(key) {
  var builder = document.getElementById('pt_builder_' + key);
  var hidden  = document.getElementById('pt_json_' + key);
  if (!builder || !hidden) return;
  var rows = Array.from(builder.querySelectorAll('.pt-row')).map(function(row) {
    return {
      direction: row.querySelector('.pt-dir').value,
      type:      row.querySelector('.pt-type').value,
      amount:    row.querySelector('.pt-amount').value.trim(),
      frequency: row.querySelector('.pt-freq').value.trim(),
      notes:     row.querySelector('.pt-notes').value.trim()
    };
  });
  hidden.value = JSON.stringify(rows);
}

window.ptSyncAllBeforeSubmit = function() {
  document.querySelectorAll('[id^="pt_builder_"]').forEach(function(el) {
    var key = el.id.replace('pt_builder_', '');
    ptSync(key);
  });
};

// Auto-sync on any change within a builder
document.addEventListener('change', function(e) {
  var row = e.target.closest && e.target.closest('.pt-row');
  if (!row) return;
  var builder = row.closest('[id^="pt_builder_"]');
  if (!builder) return;
  ptSync(builder.id.replace('pt_builder_', ''));
});
document.addEventListener('input', function(e) {
  var row = e.target.closest && e.target.closest('.pt-row');
  if (!row) return;
  var builder = row.closest('[id^="pt_builder_"]');
  if (!builder) return;
  ptSync(builder.id.replace('pt_builder_', ''));
});
</script>
