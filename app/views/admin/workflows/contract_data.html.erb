<%# IGSIGN — Contract Data review/edit form. Driven by CafFieldSchema. %>
<% content_for :title, "Contract Data — #{@caf.contracting_party.presence || 'CAF'}" %>

<div style="max-width:860px; margin:0 auto; padding:24px 16px;">

  <%# Back link %>
  <%= link_to legal_ops_workflow_path(@caf),
        style: "color:#7B787F;text-decoration:none;font-size:13px;display:inline-flex;align-items:center;gap:4px;margin-bottom:20px;" do %>
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
    Back to workflow
  <% end %>

  <div style="margin-bottom:24px;">
    <p style="font-size:11px;color:#7B787F;letter-spacing:3px;text-transform:uppercase;margin-bottom:4px;">IGSIGN — Contract Data</p>
    <h1 style="font-size:24px;font-weight:800;color:#0B1722;margin:0;"><%= @caf.contracting_party.presence || 'Untitled Agreement' %></h1>
    <div style="width:32px;height:3px;background:#00C853;border-radius:2px;margin-top:8px;"></div>
  </div>

  <%# Parse status banner %>
  <% if @data['error'].present? %>
    <div style="background:#FEF2F2;border:1px solid #FECACA;border-radius:10px;padding:16px 20px;margin-bottom:20px;color:#DC2626;">
      <strong>Automatic extraction failed:</strong> <%= @data['error'] %>.
      Please complete the fields below manually.
    </div>
  <% elsif @data.blank? %>
    <div style="background:#FFFBEB;border:1px solid #FDE68A;border-radius:10px;padding:16px 20px;margin-bottom:20px;color:#92400E;">
      Extraction is pending or has not run. Fields shown are empty.
    </div>
  <% elsif CafFieldSchema.dashboard_fields.all? { |f| @data[f[:key].to_s].present? || @caf.public_send(f[:caf_column]).present? rescue false } %>
    <div style="background:#ECFDF5;border:1px solid #A7F3D0;border-radius:10px;padding:16px 20px;margin-bottom:20px;color:#065F46;">
      Contract data complete.
    </div>
  <% end %>

  <%# Re-parse button %>
  <div style="display:flex;justify-content:flex-end;margin-bottom:20px;">
    <%= button_to reparse_legal_ops_workflow_path(@caf), method: :post,
          style: "background:#F3F4F6;color:#374151;border:none;border-radius:8px;padding:8px 16px;font-size:13px;cursor:pointer;",
          data: { confirm: "Re-parsing will overwrite AI-extracted fields but preserve manually entered fields. Continue?" },
          form: { data: { turbo: false } } do %>
      Re-parse contract
    <% end %>
  </div>

  <%= form_with url: contract_data_legal_ops_workflow_path(@caf), method: :patch,
        data: { turbo: false },
        style: "display:block;" do |f| %>

    <% @fields.each do |field| %>
      <% key = field[:key].to_s %>
      <% current_value = @data[key] %>
      <% prov = @provenance[key] %>

      <div style="background:#fff;border:1px solid #E5E7EB;border-radius:10px;padding:20px;margin-bottom:16px;">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;">
          <label for="field_<%= key %>" style="font-size:13px;font-weight:700;color:#0B1722;">
            <%= field[:label] %>
          </label>
          <% if prov == 'ai' %>
            <span style="background:#DCFCE7;color:#166534;font-size:11px;font-weight:600;padding:2px 8px;border-radius:99px;">AI</span>
          <% elsif prov == 'manual' %>
            <span style="background:#F3F4F6;color:#6B7280;font-size:11px;font-weight:600;padding:2px 8px;border-radius:99px;">Manual</span>
          <% end %>
        </div>

        <% case field[:type]
           when :enum %>
          <select id="field_<%= key %>" name="<%= key %>"
            style="width:100%;border:1px solid #D1D5DB;border-radius:6px;padding:8px 10px;font-size:13px;color:#111827;">
            <option value="">— select —</option>
            <% field[:options].each do |opt| %>
              <option value="<%= opt %>" <%= 'selected' if current_value.to_s == opt %>><%= opt %></option>
            <% end %>
          </select>

        <% when :date %>
          <input id="field_<%= key %>" name="<%= key %>" type="date"
            value="<%= current_value %>"
            style="border:1px solid #D1D5DB;border-radius:6px;padding:8px 10px;font-size:13px;color:#111827;">

        <% when :boolean %>
          <div style="display:flex;gap:16px;">
            <% [['Yes', 'true'], ['No', 'false'], ['Unknown', '']].each do |label, val| %>
              <label style="display:flex;align-items:center;gap:6px;font-size:13px;color:#374151;cursor:pointer;">
                <input type="radio" name="<%= key %>" value="<%= val %>"
                  <%= 'checked' if current_value.to_s == val || (val.blank? && current_value.nil?) %>>
                <%= label %>
              </label>
            <% end %>
          </div>

        <% when :integer %>
          <input id="field_<%= key %>" name="<%= key %>" type="number"
            value="<%= current_value %>"
            style="border:1px solid #D1D5DB;border-radius:6px;padding:8px 10px;font-size:13px;color:#111827;width:160px;">

        <% when :text %>
          <textarea id="field_<%= key %>" name="<%= key %>" rows="4"
            style="width:100%;border:1px solid #D1D5DB;border-radius:6px;padding:8px 10px;font-size:13px;color:#111827;resize:vertical;"><%= current_value %></textarea>

        <% when :array %>
          <% if field[:options].present? %>
            <%# Array with predefined options — render as checkboxes (multi-select) %>
            <% selected_values = Array(current_value).map(&:to_s) %>
            <div style="display:flex;flex-wrap:wrap;gap:8px 16px;">
              <% field[:options].each do |opt| %>
                <label style="display:flex;align-items:center;gap:6px;font-size:13px;color:#374151;cursor:pointer;">
                  <input type="checkbox" name="<%= key %>[]" value="<%= opt %>"
                    <%= 'checked' if selected_values.include?(opt.to_s) %>
                    style="width:14px;height:14px;">
                  <%= opt %>
                </label>
              <% end %>
            </div>
          <% else %>
            <%# Free-form array — one item per line textarea %>
            <textarea id="field_<%= key %>" name="<%= key %>" rows="3"
              style="width:100%;border:1px solid #D1D5DB;border-radius:6px;padding:8px 10px;font-size:13px;color:#111827;resize:vertical;"
              placeholder="One item per line"><%= Array(current_value).join("\n") %></textarea>
          <% end %>

        <% else %>
          <input id="field_<%= key %>" name="<%= key %>" type="text"
            value="<%= current_value %>"
            style="width:100%;border:1px solid #D1D5DB;border-radius:6px;padding:8px 10px;font-size:13px;color:#111827;">
        <% end %>
      </div>
    <% end %>

    <div style="margin-top:24px;display:flex;justify-content:flex-end;">
      <button type="submit"
        style="background:#00C853;color:#fff;border:none;border-radius:8px;padding:12px 28px;font-size:14px;font-weight:700;cursor:pointer;">
        Save contract data
      </button>
    </div>
  <% end %>

</div>
