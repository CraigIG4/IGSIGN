<%# IGSIGN — Edit CAF Workflow (admin, draft only) %>
<div style="max-width:760px; margin:0 auto; padding:24px 16px;">

  <%# Back link %>
  <%= link_to legal_ops_workflow_path(@caf),
      style: 'color:#7B787F;text-decoration:none;font-size:13px;display:flex;align-items:center;gap:4px;margin-bottom:20px;width:fit-content;' do %>
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
    Back to CAF
  <% end %>

  <%# Header %>
  <div style="margin-bottom:24px;">
    <div style="font-size:11px;color:#7B787F;letter-spacing:3px;text-transform:uppercase;margin-bottom:6px;">IGSIGN · LEGAL OPS</div>
    <h1 style="font-size:22px;font-weight:800;color:#162B3C;letter-spacing:-0.03em;margin:0;">
      Edit CAF — <span style="color:#45AC34;"><%= @caf.contracting_party.presence || 'Draft' %></span>
    </h1>
    <div style="width:32px;height:3px;background:#45AC34;border-radius:2px;margin-top:8px;"></div>
  </div>

  <% unless @caf.draft? %>
    <div class="alert alert-warning mb-4" style="border-left:4px solid #ffc107;padding:12px 16px;background:#fffbf0;border-radius:8px;font-size:13px;color:#162B3C;margin-bottom:20px;">
      <strong>Warning:</strong> This CAF is no longer a draft (<%= @caf.status_label %>). Editing may cause inconsistencies with the active submission.
    </div>
  <% end %>

  <% if @caf.errors.any? %>
    <div class="alert alert-error mb-4" style="margin-bottom:20px;">
      <ul style="margin:0;padding-left:16px;">
        <% @caf.errors.full_messages.each do |msg| %>
          <li style="font-size:13px;"><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with model: @caf, url: legal_ops_workflow_path(@caf), method: :patch,
                html: { enctype: 'multipart/form-data' }, local: true do |f| %>

    <div class="card" style="background:#fff;border-radius:14px;border:1px solid #edf0f3;padding:24px;margin-bottom:20px;">
      <h3 style="font-size:13px;font-weight:700;color:#7B787F;letter-spacing:2px;text-transform:uppercase;margin:0 0 16px;">Agreement Details</h3>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;">
        <div>
          <label style="display:block;font-size:13px;font-weight:600;color:#162B3C;margin-bottom:4px;">CAF Type</label>
          <%= f.select :caf_type,
                [['NDA', 'nda'], ['Short Form CAF', 'short_form'], ['Long Form CAF', 'long_form']],
                {},
                class: 'select select-bordered w-full', style: 'font-size:13px;' %>
        </div>
        <div>
          <label style="display:block;font-size:13px;font-weight:600;color:#162B3C;margin-bottom:4px;">Ignition Entity</label>
          <%= f.select :entity,
                IgEntity.active.ordered.map { |e| [e.name, e.key] },
                {},
                class: 'select select-bordered w-full', style: 'font-size:13px;' %>
        </div>
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;">
        <div>
          <label style="display:block;font-size:13px;font-weight:600;color:#162B3C;margin-bottom:4px;">Requestor Name</label>
          <%= f.text_field :requestor_name, class: 'input input-bordered w-full', style: 'font-size:13px;', placeholder: 'Full name' %>
        </div>
        <div>
          <label style="display:block;font-size:13px;font-weight:600;color:#162B3C;margin-bottom:4px;">Requestor Email</label>
          <%= f.email_field :requestor_email, class: 'input input-bordered w-full', style: 'font-size:13px;', placeholder: 'email@ignitiongroup.co.za' %>
        </div>
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;">
        <div>
          <label style="display:block;font-size:13px;font-weight:600;color:#162B3C;margin-bottom:4px;">Contracting Party <span style="color:#e53e3e;">*</span></label>
          <%= f.text_field :contracting_party, class: 'input input-bordered w-full', style: 'font-size:13px;', placeholder: 'e.g. Acme Corp Pty Ltd', required: true %>
        </div>
        <div>
          <label style="display:block;font-size:13px;font-weight:600;color:#162B3C;margin-bottom:4px;">Ignition Company</label>
          <%= f.text_field :ignition_company, class: 'input input-bordered w-full', style: 'font-size:13px;', placeholder: 'e.g. Comit Technologies' %>
        </div>
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;">
        <div>
          <label style="display:block;font-size:13px;font-weight:600;color:#162B3C;margin-bottom:4px;">Counterparty Contact Name</label>
          <%= f.text_field :counterparty_name, class: 'input input-bordered w-full', style: 'font-size:13px;', placeholder: 'Authorised signatory name' %>
        </div>
        <div>
          <label style="display:block;font-size:13px;font-weight:600;color:#162B3C;margin-bottom:4px;">Counterparty Email <span style="color:#e53e3e;">*</span></label>
          <%= f.email_field :counterparty_email, class: 'input input-bordered w-full', style: 'font-size:13px;', placeholder: 'signatory@counterparty.com', required: true %>
        </div>
      </div>

      <div style="margin-bottom:16px;">
        <label style="display:block;font-size:13px;font-weight:600;color:#162B3C;margin-bottom:4px;">High Level Summary <span style="color:#e53e3e;">*</span></label>
        <%= f.text_area :high_level_summary, rows: 4, class: 'textarea textarea-bordered w-full', style: 'font-size:13px;resize:vertical;', placeholder: 'Briefly describe the purpose and nature of this agreement...', required: true %>
      </div>

      <div>
        <label style="display:block;font-size:13px;font-weight:600;color:#162B3C;margin-bottom:4px;">NDA Mandate Description</label>
        <%= f.text_area :mandate_description, rows: 3, class: 'textarea textarea-bordered w-full', style: 'font-size:13px;resize:vertical;', placeholder: 'For NDA type only — describe the mandate...' %>
      </div>
    </div>

    <div class="card" style="background:#fff;border-radius:14px;border:1px solid #edf0f3;padding:24px;margin-bottom:20px;">
      <h3 style="font-size:13px;font-weight:700;color:#7B787F;letter-spacing:2px;text-transform:uppercase;margin:0 0 12px;">Replace Contract Document</h3>
      <p style="font-size:12px;color:#7B787F;margin-bottom:12px;">Leave blank to keep the existing document.</p>
      <% if @caf.contract_document.attached? %>
        <div style="font-size:13px;color:#162B3C;font-weight:600;margin-bottom:10px;">
          Current: <%= @caf.contract_document.filename %>
        </div>
      <% end %>
      <%= f.file_field :contract_document, accept: '.pdf,.doc,.docx,application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document',
          style: 'font-size:13px;' %>
    </div>

    <div style="display:flex;gap:12px;align-items:center;">
      <%= f.submit 'Save Changes',
            class: 'btn btn-primary',
            style: 'min-width:140px;' %>
      <%= link_to 'Cancel', legal_ops_workflow_path(@caf),
            style: 'font-size:14px;color:#7B787F;text-decoration:none;' %>
    </div>

  <% end %>
</div>
